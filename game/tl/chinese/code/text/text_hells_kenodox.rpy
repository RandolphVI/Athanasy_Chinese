# game/code/text/text_hells_kenodox.rpy:14
translate chinese kenodox_f6b2c82b:

    # Kav "Рублю… Рублю!.. Нормально. Спокойно."
    Kav "切……切！……没事。冷静。"

# game/code/text/text_hells_kenodox.rpy:15
translate chinese kenodox_25c7cecd:

    # Kav "Хе-хе-хе-хе. Хе-хе-хе."
    Kav "嘿嘿嘿嘿嘿。嘿嘿嘿嘿。"

# game/code/text/text_hells_kenodox.rpy:16
translate chinese kenodox_443d3c38:

    # Kav "Руб… О-о-о…"
    Kav "切……呃哦……"

# game/code/text/text_hells_kenodox.rpy:19
translate chinese kenodox_fe8cd1f0:

    # Kav "Красиво. Красивая."
    Kav "漂亮。漂亮。"

# game/code/text/text_hells_kenodox.rpy:20
translate chinese kenodox_d1d4cfa3:

    # Kav "Нравится."
    Kav "我喜欢。"

# game/code/text/text_hells_kenodox.rpy:21
translate chinese kenodox_024778e9:

    # Kav "Раз-два. Раз-два."
    Kav "一二。一二。"

# game/code/text/text_hells_kenodox.rpy:22
translate chinese kenodox_30b549ab:

    # Kav "Вторая не нравится."
    Kav "我不喜欢第二个。"

# game/code/text/text_hells_kenodox.rpy:23
translate chinese kenodox_921cedcf:

    # Kav "Больно."
    Kav "好疼。"

# game/code/text/text_hells_kenodox.rpy:25
translate chinese kenodox_bf34a148:

    # Kav "Огоньки… Много огоньков. Красивые."
    Kav "灯……好多灯。漂亮。"

# game/code/text/text_hells_kenodox.rpy:26
translate chinese kenodox_654bf77b:

    # Kav "Мало. Мало. Раньше больше."
    Kav "少了。不够。以前更多。"

# game/code/text/text_hells_kenodox.rpy:27
translate chinese kenodox_1e3965de:

    # Kav "Я. Я порубил огоньки. Грустно."
    Kav "我。我把灯切掉了。难过。"

# game/code/text/text_hells_kenodox.rpy:28
translate chinese kenodox_1e7afbde:

    # Kav "Плохо."
    Kav "不好。"

# game/code/text/text_hells_kenodox.rpy:29
translate chinese kenodox_b636032e:

    # Kav "Хе-хе-хе-хе."
    Kav "嘿嘿嘿嘿。"

# game/code/text/text_hells_kenodox.rpy:44
translate chinese kenodox_a1e17929:

    # OldMiner "Глупый. Слышишь меня?"
    OldMiner "蠢货。听见没？"

# game/code/text/text_hells_kenodox.rpy:45
translate chinese kenodox_35736199:

    # Kav "Рублю! Я рублю! Раз-два. Раз-два. Хе-хе-хе."
    Kav "我砍！我切！一二。一二。嘿嘿嘿嘿。"

# game/code/text/text_hells_kenodox.rpy:46
translate chinese kenodox_03933179:

    # OldMiner "Эй, Глупый! Сколько ты уже не спишь?"
    OldMiner "嘿，蠢货！你多久没睡了？"

# game/code/text/text_hells_kenodox.rpy:47
translate chinese kenodox_b3b88a89:

    # Kav "Норма… Нормально. Рублю!"
    Kav "没事……没事。我切！"

# game/code/text/text_hells_kenodox.rpy:48
translate chinese kenodox_fa89f20f:

    # OldMiner "Совсем плох. Совсем глупый. Хуже меня стал."
    OldMiner "一点都不好。真蠢。比我还糟。"

# game/code/text/text_hells_kenodox.rpy:49
translate chinese kenodox_a740ea42:

    # Kav "Плох… Плохо. Больно."
    Kav "不好……不好。疼。"

# game/code/text/text_hells_kenodox.rpy:50
translate chinese kenodox_de1e0ae6:

    # OldMiner "Ты ел? Когда ты ел последний раз?"
    OldMiner "你吃了吗？上次吃东西是什么时候？"

# game/code/text/text_hells_kenodox.rpy:57
translate chinese kenodox_357e2ff2:

    # Kav "Е-е-ел?.."
    Kav "吃……吃？"

# game/code/text/text_hells_kenodox.rpy:58
translate chinese kenodox_cf7fb347:

    # OldMiner "Зоб. Помнишь его? Помнишь Зоба?"
    OldMiner "甲瘤。你还记得他吗？记得甲瘤吗？"

# game/code/text/text_hells_kenodox.rpy:59
translate chinese kenodox_a082fe20:

    # Kav "Е-ел… Нет. Работать. Работай!"
    Kav "吃……没。工作。工作！"

# game/code/text/text_hells_kenodox.rpy:71
translate chinese kenodox_cdcfad3f:

    # OldMiner "Ай! Ты не меня бей, ты стену бей!"
    OldMiner "嗷！别打我。打墙去！"

# game/code/text/text_hells_kenodox.rpy:75
translate chinese kenodox_e5b3f8f1:

    # OldMiner "Нет, стой, хватит с тебя. Когда одна работа и больше ничего, то ты ляжешь и больше не встанешь."
    OldMiner "不，等等，你够了。当只有一份工作别无他事时，你会躺下再也起不来。"

# game/code/text/text_hells_kenodox.rpy:76
translate chinese kenodox_4e2b2652:

    # Kav "Работа! Верх. Град. Работа."
    Kav "工作！起来。堡。工作。"

# game/code/text/text_hells_kenodox.rpy:77
translate chinese kenodox_3c4c7be6:

    # OldMiner "Овощей в Град не берут. Пойдём, Зоб тебя накормит. Или ты накормишь Зоба."
    OldMiner "他们不送蔬菜去堡。来，甲瘤会喂你。不然，你就喂甲瘤。"

# game/code/text/text_hells_kenodox.rpy:78
translate chinese kenodox_f30cab93:

    # Kav "Не-е-е-ет."
    Kav "不——要——。"

# game/code/text/text_hells_kenodox.rpy:89
translate chinese kenodox_04afe30d:

    # OldMiner "Иди, или ударю ещё раз."
    OldMiner "走，不然我再打你。"

# game/code/text/text_hells_kenodox.rpy:90
translate chinese kenodox_7ec41c6f:

    # Kav "Больно! Больно…"
    Kav "好疼！好疼……"

# game/code/text/text_hells_kenodox.rpy:91
translate chinese kenodox_8f3febbf:

    # OldMiner "Вперёд иди."
    OldMiner "去吧。"

# game/code/text/text_hells_kenodox.rpy:97
translate chinese kenodox_359045a7:

    # This "Дом…"
    This "家……"

# game/code/text/text_hells_kenodox.rpy:98
translate chinese kenodox_144ca6d2:

    # Kav "Отпусти."
    Kav "放开。"

# game/code/text/text_hells_kenodox.rpy:104
translate chinese kenodox_7e662c79:

    # OldMiner "Ага, заметил меня наконец? Хорошо. Пора поесть. А где Зоб?"
    OldMiner "啊哈，你终于注意到我了？很好。该吃饭了。甲瘤在哪？"

# game/code/text/text_hells_kenodox.rpy:105
translate chinese kenodox_f8b82ad6:

    # This "Плохо. Под ногами дрожит."
    This "不对劲。脚下在颤抖。"

# game/code/text/text_hells_kenodox.rpy:106
translate chinese kenodox_ed4bd93b:

    # Kav "Отпусти! Мяско говорит — идёт плохое!"
    Kav "放开！肉说坏事要来了！"

# game/code/text/text_hells_kenodox.rpy:107
translate chinese kenodox_8ebde8f9:

    # OldMiner "Ты же Глупый, откуда… Ой."
    OldMiner "你是蠢货。怎么……哦。"

# game/code/text/text_hells_kenodox.rpy:122
translate chinese kenodox_131b8034:

    # This "Нет… Нет. Страшно."
    This "不……不。可怕。"

# game/code/text/text_hells_kenodox.rpy:131
translate chinese kenodox_ba3e7e00:

    # OldMiner "Госпожа Горечь, я тут как раз… Отловил Глупого вот."
    OldMiner "苦涩夫人，我只是……我只是抓到了这个蠢货。"

# game/code/text/text_hells_kenodox.rpy:132
translate chinese kenodox_4232a7ce:

    # Kav "Нет! Отпусти! По… пожалуйста…"
    Kav "不！放开！求求你……求求你……"

# game/code/text/text_hells_kenodox.rpy:139
translate chinese kenodox_9aff6f33:

    # Bitt "Что ты с ним сделал?! Он был совсем свежий!"
    Bitt "你对他做了什么？！他本来是新鲜的！"

# game/code/text/text_hells_kenodox.rpy:148
translate chinese kenodox_77c30797:

    # OldMiner "Ничего! Ничего, это он сам. Не спал, не отдыхал."
    OldMiner "没有！没有，是他自己。不睡觉，不休息。"

# game/code/text/text_hells_kenodox.rpy:155
translate chinese kenodox_a461d046:

    # Bitt "Умолкни. Исчезни."
    Bitt "闭嘴。消失。"

# game/code/text/text_hells_kenodox.rpy:157
translate chinese kenodox_b13637c8:

    # This "Смотрит… Смотрит. Шевелит пальцами."
    This "她看着……她看着。她动着手指。"

# game/code/text/text_hells_kenodox.rpy:158
translate chinese kenodox_a3574ce9:

    # Kav "Я… Работать."
    Kav "我……工作。"

# game/code/text/text_hells_kenodox.rpy:160
translate chinese kenodox_74fd671f:

    # Bitt "Какая жалкая попытка побега. Но я знаю, что ты где-то там, внутри. Ты слышишь."
    Bitt "多么可悲的逃跑尝试。但我知道你在里面某个地方。你能听见我。"

# game/code/text/text_hells_kenodox.rpy:162
translate chinese kenodox_520f08b1:

    # Kav "Н-нет…"
    Kav "不……不……"

# game/code/text/text_hells_kenodox.rpy:164
translate chinese kenodox_580629fa:

    # Bitt "Ты вернёшься, даже если мне придётся выжимать из тебя реакцию, как воду из куска мяса."
    Bitt "你会回来的，即使我得从你身上榨出反应，就像从一块肉里挤出水一样。"

# game/code/text/text_hells_kenodox.rpy:165
translate chinese kenodox_148037fb:

    # This "Страшно! Пусть она уйдёт."
    This "可怕！让她走。"

# game/code/text/text_hells_kenodox.rpy:167
translate chinese kenodox_f6c9c1fc:

    # Bitt "Как тебя зовут?"
    Bitt "你叫什么名字？"

# game/code/text/text_hells_kenodox.rpy:168
translate chinese kenodox_eb19d1cf:

    # This "Не говори ей. Не говори. Нет."
    This "别告诉她。别告诉她。不。"

# game/code/text/text_hells_kenodox.rpy:169
translate chinese kenodox_32f9632e:

    # Kav "Глупый."
    Kav "蠢货。"

# game/code/text/text_hells_kenodox.rpy:171
translate chinese kenodox_6f4ba07b:

    # Bitt "Ты любишь свою кирку, Глупый?"
    Bitt "你喜欢你的镐吗，蠢货？"

# game/code/text/text_hells_kenodox.rpy:179
translate chinese kenodox_70b402c2:

    # Kav "Красивая. Раз-два."
    Kav "漂亮。一二。"

# game/code/text/text_hells_kenodox.rpy:181
translate chinese kenodox_a5e78b7f:

    # Bitt "Молодец. Правильный ответ."
    Bitt "很好。正确答案。"

# game/code/text/text_hells_kenodox.rpy:183
translate chinese kenodox_f311db82:

    # Bitt "Любишь рубить ею людей?"
    Bitt "你喜欢用它砍人吗？"

# game/code/text/text_hells_kenodox.rpy:185
translate chinese kenodox_02cffb19:

    # Kav "Н-нет. Нет. Плохо. Больно."
    Kav "不……不。不好。会疼。"

# game/code/text/text_hells_kenodox.rpy:187
translate chinese kenodox_868fb693:

    # Bitt "Неправильный ответ. Ты должен знать, что следует за неправильным ответом. Дай мне свою руку. Нет-нет, другую, пятипалую."
    Bitt "错误答案。你必须知道错误答案的后果。把手给我。不，不，另一只，那只五根手指的。"

# game/code/text/text_hells_kenodox.rpy:189
translate chinese kenodox_27df557c:

    # This "Рука. Такая… Розовая. Странно. Много кожи. Мало мяса."
    This "手。它真……粉红。好怪。好多皮。没多少肉。"

# game/code/text/text_hells_kenodox.rpy:190
translate chinese kenodox_ec9379dd:

    # Bitt "Лучше закрой глаза, Глупый. Не будем торопиться."
    Bitt "最好闭上眼睛，蠢货。我们慢慢来。"

# game/code/text/text_hells_kenodox.rpy:194
translate chinese kenodox_d9a52b41:

    # This "Больно! Больно!"
    This "好疼！好疼！"

# game/code/text/text_hells_kenodox.rpy:198
translate chinese kenodox_a5de65c7:

    # Kav "А-а-ах!.."
    Kav "啊！"

# game/code/text/text_hells_kenodox.rpy:199
translate chinese kenodox_5755273f:

    # Bitt "Всё, всё, не плачь. Уже закончилось. Можешь открыть глаза."
    Bitt "好了，好了，别哭了。现在结束了。你可以睁开眼睛了。"

# game/code/text/text_hells_kenodox.rpy:202
translate chinese kenodox_1bc88b59:

    # This "Горячо… Рука, горячая снаружи. И онемевшая внутри."
    This "烫……我的手，外面烫。里面麻了。"

# game/code/text/text_hells_kenodox.rpy:203
translate chinese kenodox_ff8a5743:

    # This "Я моргнул и прищурился. Мир чуть прояснился и перестал двоиться. Вот только до этого всё двоилось и расплывалось не в глазах, а в голове."
    This "我眨了眨眼，眯起眼睛。世界清晰了一点，不再模糊。只不过模糊的是我的脑袋，不是眼睛。"

# game/code/text/text_hells_kenodox.rpy:208
translate chinese kenodox_f328a837:

    # Bitt "О, этот взгляд… Кажется, кто-то почти вернулся. Посмотрим, усвоен ли урок."
    Bitt "哦，这眼神……我想有人快回来了。看看这课学会了没。"

# game/code/text/text_hells_kenodox.rpy:210
translate chinese kenodox_bcf78ba8:

    # Bitt "Что будет за неправильный ответ?"
    Bitt "如果你给出错误答案会怎样？"

# game/code/text/text_hells_kenodox.rpy:218
translate chinese kenodox_9884bc48:

    # Kav "Боль."
    Kav "疼。"

# game/code/text/text_hells_kenodox.rpy:220
translate chinese kenodox_1c340235:

    # This "По десяткам пальцев Горечи прошлась волна суетливого движения."
    This "苦涩的几十根手指一阵躁动。"

# game/code/text/text_hells_kenodox.rpy:221
translate chinese kenodox_7bfc9826:

    # Bitt "Да. А какой ответ неправильный — решаю я."
    Bitt "没错。而且由我决定哪个答案是错的。"

# game/code/text/text_hells_kenodox.rpy:225
translate chinese kenodox_56ea4757:

    # Bitt "Стало ли тебе жарко? Участилось биение сердца? Может, хочешь кого-нибудь ударить?"
    Bitt "你觉得热吗？心跳更快了吗？有没有想打人？"

# game/code/text/text_hells_kenodox.rpy:227
translate chinese kenodox_71265e07:

    # This "Да. Хочу отрубить твою мерзкую голову. Чтобы она шмякнулась на пол и побежала по нему на своих маленьких ножках-пальцах."
    This "想。我想砍掉你丑陋的脑袋。想让它掉到地上，用它的小趾腿在上面跳。"

# game/code/text/text_hells_kenodox.rpy:228
translate chinese kenodox_ec381526:

    # Kav "Да. Стало жарко в груди."
    Kav "嗯。我胸口觉得热。"

# game/code/text/text_hells_kenodox.rpy:232
translate chinese kenodox_b51aa5ca:

    # Bitt "Молодец. Готов идти?"
    Bitt "好孩子。准备好走了吗？"

# game/code/text/text_hells_kenodox.rpy:233
translate chinese kenodox_4d55ef7c:

    # Kav "Куда?"
    Kav "去哪？"

# game/code/text/text_hells_kenodox.rpy:235
translate chinese kenodox_1532aeed:

    # Bitt "Подальше от этой убогой дыры. Или ты твёрдо решил накормить Зоба?"
    Bitt "离开这个破洞。还是说，你决心要喂甲瘤？"

# game/code/text/text_hells_kenodox.rpy:237
translate chinese kenodox_05b7c429:

    # Kav "Но… Работа. Норма Выработки. Я хочу в Град."
    Kav "可是……工作。生产配额。我想去堡。"

# game/code/text/text_hells_kenodox.rpy:239
translate chinese kenodox_240c9edc:

    # This "Её смех прозвучал так радостно и ярко, что я сам невольно улыбнулся. Почему этому существу позволено иметь такой чистый голос? Так быть не должно. Это неправильно."
    This "她的笑声听起来如此欢快明亮，我不由自主地也笑了。为什么允许这种生物拥有如此清澈的嗓音？不该这样的。这不公平。"

# game/code/text/text_hells_kenodox.rpy:240
translate chinese kenodox_1fd13a27:

    # Bitt "Ты попадёшь в Град. Когда наскучишь мне."
    Bitt "你会进堡的。等你让我厌烦的时候。"

# game/code/text/text_hells_kenodox.rpy:242
translate chinese kenodox_320d87ff:

    # Bitt "Но отсюда в Град не попадёт никто. Шахтёры кормят Зоба. Зоб кормит шахтёров. Все на своих местах."
    Bitt "但没人能从这儿进堡。矿工喂甲瘤。甲瘤喂矿工。各得其所。"

# game/code/text/text_hells_kenodox.rpy:244
translate chinese kenodox_f02c29fa:

    # This "Она может провести меня в Град?!.."
    This "她能让我进堡？！……"

# game/code/text/text_hells_kenodox.rpy:245
translate chinese kenodox_aefb555a:

    # This "Нет. Надежда — это просто ещё одно из её лезвий."
    This "不。希望不过是她的又一把刀刃。"

# game/code/text/text_hells_kenodox.rpy:246
translate chinese kenodox_dbc021b6:

    # Kav "Я не верю тебе. Я столько работал…"
    Kav "我不信你。我一直那么努力……"

# game/code/text/text_hells_kenodox.rpy:250
translate chinese kenodox_1961fff9:

    # Bitt "Количество твоих усилий делает правду только веселее. Что ты чувствуешь? Обиду? Ты в гневе? Ну же, расскажи."
    Bitt "你付出的努力越多，真相就越有趣。你感觉如何？怨恨？生气了吗？来嘛，告诉我。"

# game/code/text/text_hells_kenodox.rpy:252
translate chinese kenodox_d862592d:

    # This "Почему в душе засела уверенность в её правоте?"
    This "为什么我心底如此确信她是对的？"

# game/code/text/text_hells_kenodox.rpy:253
translate chinese kenodox_39c52fb6:

    # Kav "Тогда зачем всё это?"
    Kav "那这一切都是为了什么？"

# game/code/text/text_hells_kenodox.rpy:255
translate chinese kenodox_053aa858:

    # Bitt "Зачем? Это неважно. Это жизнь. У неё нет ни смысла, ни цели. Может быть, всё это существует, чтобы веселить меня."
    Bitt "你问为什么？其实无关紧要。这就是生活。它没有意义或目的。也许这一切的存在只是为了取悦我。"

# game/code/text/text_hells_kenodox.rpy:257
translate chinese kenodox_c38bb4d8:

    # Bitt "А теперь пойдём. Тут воняет."
    Bitt "现在，走吧。这儿臭死了。"

# game/code/text/text_hells_kenodox.rpy:259
translate chinese kenodox_4a7660bf:

    # This "Рука перестала гореть и неметь. Теперь она просто ныла — нудная и противная боль. Скучное страдание."
    This "我的手不再灼烧或麻木。现在它只是隐隐作痛，一种沉闷而恼人的痛楚。钝钝的折磨。"

# game/code/text/text_hells_kenodox.rpy:260
translate chinese kenodox_88749879:

    # This "Другое место ничем не хуже этого."
    This "另一个地方并不比这里更糟。"

# game/code/text/text_hells_kenodox.rpy:265
translate chinese kenodox_caa902f1:

    # This "Истончилась плоть на стенах. Чем дальше от шахт — тем она скуднее выглядит."
    This "墙上的肉变薄了。离矿井越远，肉看起来就越稀少。"

# game/code/text/text_hells_kenodox.rpy:266
translate chinese kenodox_a9d9876d:

    # This "Тяжёлый ком собрался в затылке. Давит на мозг. Хочется расслабить глаза — пусть они смотрят, не видя. Пусть слепо пялятся на беспорядочные узоры мяса вокруг."
    This "后脑勺聚起一个沉重的肿块。它压迫着我的大脑。我想放松眼睛——让它们视而不见地瞪着。让它们盲目地瞪着周围肉壁的随机纹路。"

# game/code/text/text_hells_kenodox.rpy:267
translate chinese kenodox_8fc06f24:

    # This "Хочется опять отпустить на свободу мысли и слова. Остаться пустым и чистым."
    This "我想再次放开思想和言语，让它们自由。变得空洞而纯净。"

# game/code/text/text_hells_kenodox.rpy:268
translate chinese kenodox_bd053694:

    # This "Стоит только расплестись сознанию — тут же в него вонзается острый шип боли из порезанной руки. Вокруг этого шипа собираются чувства и образы. Срастаются обратно в единое Я."
    This "意识刚一敞开，受伤的手传来的尖锐痛刺就扎了进来。感受与意象围绕着这根刺聚集。然后它们重新融合成一个单一的自我。"

# game/code/text/text_hells_kenodox.rpy:269
translate chinese kenodox_b4a45701:

    # This "Чем больше вырастает это Я — тем больше оно чувствует боль, тем сильнее и прочнее оно становится. Теперь не удастся сбежать в бессознательность."
    This "这个自我越是成长——它感受到的痛楚就越多，它就变得越强大。现在已无法逃入无意识了。"

# game/code/text/text_hells_kenodox.rpy:270
translate chinese kenodox_149148de:

    # This "Упрямо и тупо это Я тащит за собой из глубин память."
    This "这个自我顽固而笨拙地从我脑海深处拖拽出记忆。"

# game/code/text/text_hells_kenodox.rpy:271
translate chinese kenodox_b995e860:

    # This "Надо было принять предложение Старшего Смены. Надо было пойти в пищу Зобу."
    This "我本该接受工头职位的。我本该去喂甲瘤的。"

# game/code/text/text_hells_kenodox.rpy:272
translate chinese kenodox_b9765f91:

    # This "Скрипя зубами, я сжимаю раненую руку в кулак. Кровь больше не идёт — края раны схватились и спаялись обратно. Но боль всё ещё там; тень воспоминания в толще плоти."
    This "我咬紧牙关，将受伤的手攥成拳头。血已经不流了——伤口边缘已经黏连愈合。但痛楚仍在——那是深植血肉中的记忆阴影。"

# game/code/text/text_hells_kenodox.rpy:275
translate chinese kenodox_d28c6af9:

    # This "Воздух неприятно холодит тело. Уютные испарения шахт сменились терпким и непривычным запахом. Кажется, так пахнет камень."
    This "空气让身体感到不适的寒冷。矿井里舒适的蒸汽被一种酸涩陌生的气味取代。似乎是石头的味道。"

# game/code/text/text_hells_kenodox.rpy:276
translate chinese kenodox_2d6a5319:

    # This "Вечный щебет и треск плоти в стенах сменился на беззвучный шёпот. Когда-то он сводил меня с ума — теперь хотелось хлопать себя по ушам, чтобы заглушить мучительную тишину."
    This "墙壁中永恒的肉体啁啾声和噼啪声被寂静的低语取代。曾几何时，这曾让我发疯——现在我却想拍打耳朵来阻止这痛苦的寂静。"

# game/code/text/text_hells_kenodox.rpy:277
translate chinese kenodox_59a28721:

    # This "Ужасное место. Град не может быть в этой стороне. Никто не может жить на голом камне, оторванным от живого и влажного тепла."
    This "这是个可怕的地方。堡不可能是这样的。没人能生活在光秃秃的岩石上，与鲜活潮湿的温暖隔绝。"

# game/code/text/text_hells_kenodox.rpy:278
translate chinese kenodox_126f07f1:

    # Kav "Стой. Стой."
    Kav "停下。停下。"

# game/code/text/text_hells_kenodox.rpy:284
translate chinese kenodox_c8931679:

    # Bitt "Если это просьба, то ты должен умолять выразительнее. Если приказ — должен говорить громче."
    Bitt "如果是请求，你得恳求得更有力些。如果是命令，你该说得更大声。"

# game/code/text/text_hells_kenodox.rpy:286
translate chinese kenodox_ec4fb4bf:

    # Kav "Разве я могу тебе приказывать?"
    Kav "我能命令你吗？"

# game/code/text/text_hells_kenodox.rpy:288
translate chinese kenodox_0fd46bb4:

    # Bitt "Если сможешь заставить меня подчиняться."
    Bitt "如果你能让我服从的话。"

# game/code/text/text_hells_kenodox.rpy:289
translate chinese kenodox_f8596a7f:

    # This "Её рука жадно пробежалась гребенчатым набором пальцев по синим узорам на груди."
    This "她的手贪婪地用扇贝状的指节划过胸前的蓝色纹路。"

# game/code/text/text_hells_kenodox.rpy:290
translate chinese kenodox_b1402b06:

    # Kav "Я просто хочу задать вопрос. Я могу задавать вопросы?"
    Kav "我只是想问个问题。我能提问吗？"

# game/code/text/text_hells_kenodox.rpy:292
translate chinese kenodox_337e9b76:

    # Bitt "Зачем? Чтобы ты тоже мог наказывать меня за неправильные ответы?"
    Bitt "为什么？这样你也能为错误的答案惩罚我吗？"

# game/code/text/text_hells_kenodox.rpy:294
translate chinese kenodox_7a92eecd:

    # This "Ещё одно путешествие многосуставных отростков по влажной и блестящей коже."
    This "又一次多关节骨刺在湿润闪亮的皮肤上游走。"

# game/code/text/text_hells_kenodox.rpy:295
translate chinese kenodox_3986e1a6:

    # This "Омерзительное создание."
    This "恶心的生物。"

# game/code/text/text_hells_kenodox.rpy:297
translate chinese kenodox_48009f45:

    # Kav "Куда мы идём? Я думал, мы идём в Верх. Но вокруг становится только хуже."
    Kav "我们要去哪儿？我以为我们要去上层区。但这周围只是越来越糟。"

# game/code/text/text_hells_kenodox.rpy:299
translate chinese kenodox_99764b8e:

    # Bitt "Хуже? Чем же?"
    Bitt "更糟？怎么个糟法？"

# game/code/text/text_hells_kenodox.rpy:300
translate chinese kenodox_46926a4b:

    # Kav "Здесь меньше удобной и приятной плоти. Твёрдый камень режет подошвы. Холодный сквозняк сушит кожу."
    Kav "舒适宜人的肉变少了。坚硬的石头硌着脚底。冰冷的穿堂风干燥了皮肤。"

# game/code/text/text_hells_kenodox.rpy:302
translate chinese kenodox_92d6e233:

    # Bitt "Всё верно. Именно так живут люди в Граде. Плоть там сжата и заперта в коробки, трансформирована в холодные твёрдые блоки."
    Bitt "没错。堡里的人就是这样生活的。那里的肉被压缩装箱，变成了冰冷坚硬的块状物。"

# game/code/text/text_hells_kenodox.rpy:303
translate chinese kenodox_0330a800:

    # This "Она права, я помню это. Я был там."
    This "她说得对。我记得。我去过那里。"

# game/code/text/text_hells_kenodox.rpy:304
translate chinese kenodox_8919012e:

    # Kav "Я думал, в Граде должно быть хорошо…"
    Kav "我以为堡里应该很好……"

# game/code/text/text_hells_kenodox.rpy:305
translate chinese kenodox_d7de4168:

    # This "Было ли мне хорошо?"
    This "我在那里快乐过吗？"

# game/code/text/text_hells_kenodox.rpy:306
translate chinese kenodox_ce123e6d:

    # This "Нет. Я помню страх, волнения, беспокойство. Невыносимое одиночество."
    This "没有。我记得恐惧、不安、焦虑。还有难以忍受的孤独。"

# game/code/text/text_hells_kenodox.rpy:308
translate chinese kenodox_e8096fcc:

    # Bitt "Хорошо… Ха. Хорошо — это не место. Это состояние твоего мозга. Или ложная память о состоянии."
    Bitt "你说好……哈。好不是一个地方。它是你心灵的状态。或是这种状态的虚假记忆。"

# game/code/text/text_hells_kenodox.rpy:310
translate chinese kenodox_27c21945:

    # Kav "Да что ты знаешь об этом? Ты де…"
    Kav "你对此又知道什么？你这个……"

# game/code/text/text_hells_kenodox.rpy:312
translate chinese kenodox_21e531a7:

    # Bitt "Демон?"
    Bitt "恶魔？"

# game/code/text/text_hells_kenodox.rpy:313
translate chinese kenodox_0b874d81:

    # Kav "Нет."
    Kav "不是。"

# game/code/text/text_hells_kenodox.rpy:315
translate chinese kenodox_4c606f2d:

    # Bitt "Вот именно. Я — человек. Такой же, как и ты. Человеческих частей во мне даже больше, чем в тебе. Смотри на меня!"
    Bitt "没错。我是人类。和你一样。我身上的人类部分甚至比你还多。看着我！"

# game/code/text/text_hells_kenodox.rpy:317
translate chinese kenodox_c30f980b:

    # Bitt "С математической точки зрения я больше человек, чем ты."
    Bitt "从数学上讲，我比你更有人性。"

# game/code/text/text_hells_kenodox.rpy:318
translate chinese kenodox_33d114b2:

    # Kav "Человек — это не просто сумма слагаемых."
    Kav "人类不仅仅是其各部分的总和。"

# game/code/text/text_hells_kenodox.rpy:320
translate chinese kenodox_4fb93a36:

    # Bitt "Ого. Совсем недавно ты мычал от боли и говорил по одному слову за раз. Теперь рассуждаешь о природе человечности."
    Bitt "哇哦。不久前，你还痛得直哼哼，一次只说一个词。现在却在谈论人性的本质了。"

# game/code/text/text_hells_kenodox.rpy:322
translate chinese kenodox_c7116035:

    # Bitt "Погляди, что с тобой сделал один жалкий порез. И после этого ты смеешь злиться на свою спасительницу? Свою благодетельницу?"
    Bitt "看看一道可怜的伤口对你做了什么。之后，你还敢对你的救星生气？对你的恩人？"

# game/code/text/text_hells_kenodox.rpy:324
translate chinese kenodox_5dcfb5d6:

    # Bitt "Интересно, что с тобой будет после десятого пореза. Или сотого."
    Bitt "我好奇第十道伤口之后你会变成什么样。或者第一百道。"

# game/code/text/text_hells_kenodox.rpy:325
translate chinese kenodox_804d3bae:

    # Bitt "Думаю, мы это ещё узнаем."
    Bitt "我想我们会知道的。"

# game/code/text/text_hells_kenodox.rpy:327
translate chinese kenodox_ac93267f:

    # This "Упрямая злость пульсом застучала в висках и заглушила страх."
    This "一股固执的愤怒在我太阳穴跳动，淹没了恐惧。"

# game/code/text/text_hells_kenodox.rpy:328
translate chinese kenodox_f273cf6f:

    # This "Злость на неё; раздражение на самого себя. Опять она права. Недавно я даже не знал таких слов."
    This "我生她的气。我生自己的气。她又说对了。不久前，我甚至不知道这些词。"

# game/code/text/text_hells_kenodox.rpy:329
translate chinese kenodox_25c2b37f:

    # This "Ещё один кусок воспоминаний. Когда-то я любил математику. Статистика, аналитика, числа и схемы…"
    This "又一片记忆。曾经，我热爱数学。统计、分析、数字和图表……"

# game/code/text/text_hells_kenodox.rpy:330
translate chinese kenodox_5e4587a5:

    # This "Кто-то забрал у меня всё это. Теперь же остались только примитивные чувства и обрывки мыслей. Убогий, отвратительный недочеловек."
    This "有人把这一切从我身上夺走了。现在，我只剩下原始的情感和思想的碎片。一个可悲、恶心的亚人。"

# game/code/text/text_hells_kenodox.rpy:332
translate chinese kenodox_cac06ca2:

    # This "Чёрные провалы пещер едва освещались кривыми костяными свечами."
    This "洞穴的黑色缺口仅由歪斜的骨烛勉强照亮。"

# game/code/text/text_hells_kenodox.rpy:333
translate chinese kenodox_9599543f:

    # Kav "Что в них горит?"
    Kav "里面烧的是什么？"

# game/code/text/text_hells_kenodox.rpy:334
translate chinese kenodox_b1fd265d:

    # Bitt "Жир, конечно же. Который так стесняется использовать Град. Для них он слишком воняет."
    Bitt "当然是脂肪。堡里羞于使用的东西。你看，对他们来说太臭了。"

# game/code/text/text_hells_kenodox.rpy:335
translate chinese kenodox_4ea7362b:

    # Kav "Я не чувствую запаха."
    Kav "我闻不到。"

# game/code/text/text_hells_kenodox.rpy:336
translate chinese kenodox_c3661d0e:

    # Bitt "Потому что ты воняешь сильнее."
    Bitt "因为你更臭。"

# game/code/text/text_hells_kenodox.rpy:340
translate chinese kenodox_5d4513d4:

    # This "Тёмный проход внезапно закончился небольшим гротом. Жар свечей и влажный пар, исходящий от бассейна в полу, напоминали о плоти, так недостающей на стенах."
    This "黑暗的通道突然终止于一个小石窟。蜡烛的热量和地板水池散发的潮湿蒸汽让我想起了肉，那种现在墙上所缺乏的肉。"

# game/code/text/text_hells_kenodox.rpy:341
translate chinese kenodox_a2d513a3:

    # Kav "Это не Град."
    Kav "这不是堡。"

# game/code/text/text_hells_kenodox.rpy:342
translate chinese kenodox_316a6557:

    # This "Но почему-то очень похоже. Тесная комната с низким потолком. Даже окна нет."
    This "但不知为何，它非常相似。一个天花板低矮的狭窄房间。连窗户都没有。"

# game/code/text/text_hells_kenodox.rpy:346
translate chinese kenodox_7bd2b6ce:

    # Bitt "Конечно, это не Град. Это мой дом. Добро пожаловать."
    Bitt "当然，这不是堡。这是我家。欢迎。"

# game/code/text/text_hells_kenodox.rpy:348
translate chinese kenodox_557202e9:

    # Kav "Дом? Но где твоя семья? Как ты спишь, кем укрываешься, от кого кормишься?"
    Kav "家？但你的家人呢？你怎么睡觉，躲避谁，谁给你吃的？"

# game/code/text/text_hells_kenodox.rpy:350
translate chinese kenodox_277973b9:

    # Bitt "Тебе пора отмываться от мерзких шахтёрских привычек. То, что ты называешь семьёй — просто жалкая кучка истерзанных тел. Таких кучек в шахтах сотни. Тысячи."
    Bitt "是时候洗掉你肮脏的矿工习惯了。你所谓的家庭不过是一堆可悲的残缺躯体。矿井里有成百上千个。"

# game/code/text/text_hells_kenodox.rpy:352
translate chinese kenodox_8ba3b1ce:

    # Bitt "Тебе не нужно есть, пока твой разум ещё способен выдавать реакцию на стимул. А чем острее стимул — тем острее и реакция."
    Bitt "只要你的头脑还能对刺激作出反应，你就不需要进食。而且刺激越强烈，反应就越敏锐。"

# game/code/text/text_hells_kenodox.rpy:354
translate chinese kenodox_d1ea3099:

    # This "Кисти, сросшиеся в вечном рукопожатии на глотке Горечи, вдруг сжали пальцы так туго, что я услышал скрип кожи. Её глаза закатились под веки, поблёскивая влажными белками."
    This "苦涩喉咙上永远握在一起的手突然紧紧攥起手指，我听到了皮肤摩擦的吱嘎声。她的眼珠在眼皮下翻动，湿润的眼白闪烁着。"

# game/code/text/text_hells_kenodox.rpy:356
translate chinese kenodox_e730e0c6:

    # This "Спустя долгое, наполненное жутким хрипом мгновение пальцы расслабились, и скрип кожи сменился свистом расправляющихся лёгких."
    This "经过漫长、诡异喘息的一刻后，手指放松了，皮肤的吱嘎声被肺部展开的哨音取代。"

# game/code/text/text_hells_kenodox.rpy:359
translate chinese kenodox_62d2fa77:

    # Bitt "Кх-ха… Если же реакция притупилась, то всегда можно закусить одним из тех, кто больше не думает и не говорит."
    Bitt "咳-哈……如果反应迟钝了，你总可以吃点那些不再思考或说话的人。"

# game/code/text/text_hells_kenodox.rpy:361
translate chinese kenodox_6a853692:

    # Kav "Овощем? Почему бы не обратиться к Зобу?"
    Kav "你是说蔬菜？为什么不问甲瘤要？"

# game/code/text/text_hells_kenodox.rpy:363
translate chinese kenodox_2db6aa1a:

    # Bitt "Не люблю суп. Иногда нужно что-нибудь жевать, иначе зубы выпадут."
    Bitt "我不喜欢汤。有时候，你得嚼点东西，不然牙齿会掉。"

# game/code/text/text_hells_kenodox.rpy:365
translate chinese kenodox_40753bad:

    # Bitt "Ты ведь помнишь, что такое суп?.."
    Bitt "你还记得汤是什么，对吧？……"

# game/code/text/text_hells_kenodox.rpy:367
translate chinese kenodox_9904ced8:

    # Bitt "Это шутка. Я хочу, чтобы ты улыбнулся."
    Bitt "开个玩笑。我想让你笑一笑。"

# game/code/text/text_hells_kenodox.rpy:371
translate chinese kenodox_21c90ded:

    # Bitt "Могу пошутить, а могу разрезать тебе щёки. Сам выбирай."
    Bitt "我可以讲个笑话，也可以割开你的脸颊。你选。"

# game/code/text/text_hells_kenodox.rpy:373
translate chinese kenodox_a3eed60c:

    # This "Некоторое время я колебался, склоняясь к разрезанию щёк."
    This "我犹豫了一会儿，倾向于选择割脸颊的方案。"

# game/code/text/text_hells_kenodox.rpy:374
translate chinese kenodox_714e0c4c:

    # This "Ещё один приступ боли может вернуть больше воспоминаний, ещё больше мыслей и чувств…"
    This "再来一阵疼痛或许能唤回更多记忆、更多思想和感受……"

# game/code/text/text_hells_kenodox.rpy:375
translate chinese kenodox_f5665d57:

    # This "Нет, спасибо."
    This "不，谢了。"

# game/code/text/text_hells_kenodox.rpy:376
translate chinese kenodox_0b40233b:

    # This "Я натужно улыбнулся, чувствуя, как собирается складками дряблая кожа на щеках."
    This "我勉强笑了笑，感觉脸颊上松弛的皮肤皱了起来。"

# game/code/text/text_hells_kenodox.rpy:380
translate chinese kenodox_1440cc0d:

    # Bitt "Очень жаль."
    Bitt "真可惜。"

# game/code/text/text_hells_kenodox.rpy:384
translate chinese kenodox_57095d23:

    # Bitt "Если же хочешь отдохнуть после еды, то всегда можешь использовать мою кровать."
    Bitt "但如果你想在进食后休息，随时可以用我的床。"

# game/code/text/text_hells_kenodox.rpy:385
translate chinese kenodox_71c1188d:

    # This "Она указала сразу шестью пальцами на бассейн в полу."
    This "她同时用六根手指指向地板上的水池。"

# game/code/text/text_hells_kenodox.rpy:386
translate chinese kenodox_5a418358:

    # This "Я уставился на густой багровый бульон, наполняющий углубление до краёв. Непрерывно волнующаяся поверхность отражала в себе огни множества свечей, скрывая в глубине что-то тёмное и подвижное."
    This "我凝视着那填满坑穴、几乎要溢出的浓稠猩红肉汤。不断闪烁的表面映照着众多烛火的光芒，深处隐藏着某种黑暗而鲜活的东西。"

# game/code/text/text_hells_kenodox.rpy:387
translate chinese kenodox_1a10708d:

    # Kav "Ты спишь… в этом?"
    Kav "你……把这个当床用？"

# game/code/text/text_hells_kenodox.rpy:389
translate chinese kenodox_b60c9b5c:

    # Bitt "Отдыхаю. Судя по твоей никудышной попытке сбежать от своей участи, ты тоже научился не закрывать глаза. Не давать Плёнке шанса заговорить с тобой."
    Bitt "我在这里休息。从你试图逃避命运那徒劳的举动来看，你也学会了睁着眼睛睡觉，不给膜体跟你说话的机会。"

# game/code/text/text_hells_kenodox.rpy:391
translate chinese kenodox_4c992b65:

    # This "Тесная и маленькая комната с одной кроватью для одного-единственного человека. Как будто я уже был здесь."
    This "一个狭小拥挤的房间，只有一张床，仅供一人使用。仿佛我曾来过这里。"

# game/code/text/text_hells_kenodox.rpy:392
translate chinese kenodox_dc6fffd1:

    # This "Дом."
    This "家。"

# game/code/text/text_hells_kenodox.rpy:397
translate chinese kenodox_09e79acb:

    # This "Жарко!.."
    This "好烫……！"

# game/code/text/text_hells_kenodox.rpy:398
translate chinese kenodox_d9d8dec0:

    # This "Мутное месиво в бассейне обжигало кожу — словно стремилось разъесть и растворить в себе новую добычу."
    This "池中浑浊的混合物灼烧着我的皮肤，仿佛试图腐蚀溶解我这新来的猎物。"

# game/code/text/text_hells_kenodox.rpy:399
translate chinese kenodox_0fc48d2a:

    # This "Удивительно, но постоянное покалывание в теле действительно расслабило разум. Колючая волна ощущений затопила сознание и вымыла из него все мысли, оставив только шуршание раздражённых нервов."
    This "令人惊讶的是，身体持续的刺痛感确实让我的头脑放松下来。刺痛的浪潮淹没了我的意识，冲刷掉所有思绪，只留下受刺激神经的窸窣声。"

# game/code/text/text_hells_kenodox.rpy:400
translate chinese kenodox_4fb9dc35:

    # This "Сквозь эту завесу не пробиться никаким голосам в голове."
    This "我脑海中没有任何声音能穿透这层帷幕。"

# game/code/text/text_hells_kenodox.rpy:401
translate chinese kenodox_8ecc6f3c:

    # This "Осознав это, я так расслабился, что чуть не ушёл под воду с головой. Остановило меня только касание чужого тела."
    This "意识到这一点时，我放松得几乎要把头埋进水里。唯一阻止我的是另一具身体的触碰。"

# game/code/text/text_hells_kenodox.rpy:402
translate chinese kenodox_377d1600:

    # Kav "П-почему ты тоже?!.."
    Kav "你、你怎么也在这里？！"

# game/code/text/text_hells_kenodox.rpy:403
translate chinese kenodox_2770a04f:

    # Bitt "Это всё ещё моя кровать. А теперь умолкни."
    Bitt "这仍然是我的床。现在闭嘴。"

# game/code/text/text_hells_kenodox.rpy:404
translate chinese kenodox_1cb9292e:

    # This "…если сжаться в комок и обнять себя за плечи у стенки бассейна, то можно почти не касаться её ног…"
    This "……如果我在池壁蜷缩成团，用双臂抱住自己，就几乎碰不到她的脚……"

# game/code/text/text_hells_kenodox.rpy:406
translate chinese kenodox_7c557b4f:

    # Kav "Почему тебя так зовут?"
    Kav "他们为什么那样叫你？"

# game/code/text/text_hells_kenodox.rpy:407
translate chinese kenodox_64388df7:

    # Bitt "Знакомство со мной оставляет у людей горький привкус во рту."
    Bitt "认识我的人，嘴里都会留下苦涩的滋味。"

# game/code/text/text_hells_kenodox.rpy:408
translate chinese kenodox_bb1e6876:

    # Kav "Смешно."
    Kav "有意思。"

# game/code/text/text_hells_kenodox.rpy:409
translate chinese kenodox_1317e311:

    # Bitt "Я всё ещё могу порвать тебе щёки, раз уж ты так ленишься улыбаться."
    Bitt "我仍然可以撕掉你的脸颊，既然你懒得自己笑。"

# game/code/text/text_hells_kenodox.rpy:410
translate chinese kenodox_02716611:

    # Kav "Нет, спасибо."
    Kav "不，谢了。"

# game/code/text/text_hells_kenodox.rpy:415
translate chinese kenodox_1e59a0f9:

    # Bitt "А тебя почему так зовут? Глупым?"
    Bitt "他们为什么叫你蠢货？"

# game/code/text/text_hells_kenodox.rpy:416
translate chinese kenodox_4749b3eb:

    # Kav "Умный не оказался бы в такой ситуации."
    Kav "聪明人不会落到这般境地。"

# game/code/text/text_hells_kenodox.rpy:417
translate chinese kenodox_baab304c:

    # Bitt "Тут ты прав. Так называемые умные люди бросили нас тут. Разгребать то дерьмо, которое они натворили."
    Bitt "你说得对。所谓的聪明人把我们留在了这里。来收拾他们搞出的烂摊子。"

# game/code/text/text_hells_kenodox.rpy:418
translate chinese kenodox_2c42246c:

    # This "Её слова слились с шорохом воды в ушах. Я погрузил голову в горячий бассейн и выдохнул пузырь беззвучного крика, когда жгучая жидкость добралась до глаз."
    This "她的话语与我耳中水流的窸窣声融为一体。我将头浸入滚烫的池中，当灼热的液体触及眼睛时，呼出了一串无声尖叫的气泡。"

# game/code/text/text_hells_kenodox.rpy:419
translate chinese kenodox_08e255aa:

    # This "Пусть выгорит с болью из тела вся грязь и весь страх. Даже если после этого от меня ничего не останется."
    This "让所有的污秽和恐惧连同疼痛一起从我体内烧尽吧。即使这意味着我将不复存在。"

# game/code/text/text_hells_kenodox.rpy:425
translate chinese kenodox_8dbf5737:

    # This "Я выполз на прохладный каменный пол, содрогаясь от каждого прикосновения к грубой поверхности. Как можно существовать без живого ковра под ногами?!.."
    This "我爬到凉爽的石质地板上，粗糙表面的每一次触碰都让我颤抖。脚下没有活生生的地毯，我怎能生存？！……"

# game/code/text/text_hells_kenodox.rpy:426
translate chinese kenodox_71fe71f0:

    # This "Кожа покраснела и опухла. Теперь её оттенок напоминает цвет тел демонов."
    This "皮肤变得红肿。其色泽现在近似恶魔身体的颜色。"

# game/code/text/text_hells_kenodox.rpy:427
translate chinese kenodox_c2b14c46:

    # This "Похоже, жгучие ванны весьма популярны вне шахт."
    This "看来滚烫的浴池在矿井外相当流行。"

# game/code/text/text_hells_kenodox.rpy:431
translate chinese kenodox_81c41b92:

    # Bitt "Если тебя беспокоит зуд кожи, то мы можем её с тебя снять. Кожа — это уязвимость. В ней собрано столько чувствительности к боли…"
    Bitt "如果你担心皮肤发痒，我们可以帮你把它去掉。皮肤很脆弱。它承载了太多对疼痛的感知……"

# game/code/text/text_hells_kenodox.rpy:433
translate chinese kenodox_7fbe8d90:

    # Kav "У тебя-то, как я посмотрю, кожи избыток."
    Kav "你自己不也有太多皮肤吗？"

# game/code/text/text_hells_kenodox.rpy:434
translate chinese kenodox_441461de:

    # Bitt "Вот именно."
    Bitt "正是如此。"

# game/code/text/text_hells_kenodox.rpy:435
translate chinese kenodox_b79838d0:

    # This "Не может же ей это действительно нравиться?"
    This "她不可能真的喜欢这样，对吧？"

# game/code/text/text_hells_kenodox.rpy:436
translate chinese kenodox_0f79e99a:

    # This "Стоило только утихнуть жжению, как в голову тут же полезли надоедливые мысли. В самой ужасной своей форме — в виде вопросов."
    This "灼烧感一消退，恼人的思绪便充斥了我的脑海。而且是以最糟糕的形式——以问题的形式。"

# game/code/text/text_hells_kenodox.rpy:437
translate chinese kenodox_6a007c4a:

    # This "Я посмотрел на свою пятипалую руку."
    This "我看着自己五指的手。"

# game/code/text/text_hells_kenodox.rpy:439
translate chinese kenodox_f912ba45:

    # This "Ни следа от раны. Словно едкий раствор смыл её с тела."
    This "伤口了无痕迹。仿佛那刺鼻的液体将它从我身体上洗掉了。"

# game/code/text/text_hells_kenodox.rpy:442
translate chinese kenodox_40bce1f3:

    # Kav "Почему было так больно? Ты просто разрезала мне ладонь. Я пытался проткнуть себя киркой, и это было совсем не так."
    Kav "为什么刚才那么疼？你只是割了我的手掌。我曾试图用镐刺穿自己，那感觉完全不一样。"

# game/code/text/text_hells_kenodox.rpy:443
translate chinese kenodox_68ee780b:

    # Bitt "О-о, этот вопрос показывает, что я не ошиблась в тебе."
    Bitt "啧啧，这个问题表明我没看错你。"

# game/code/text/text_hells_kenodox.rpy:450
translate chinese kenodox_d6653734:

    # Bitt "Боль — это просто сигнал, который тело посылает мозгу. Забавно, что сам себе мозг посылать такие сообщения не может. Он не чувствует боли. Хочешь проверить?"
    Bitt "疼痛只是身体发送给大脑的信号。有趣的是，大脑无法向自己发送这样的信息。它感觉不到疼痛。你想验证一下吗？"

# game/code/text/text_hells_kenodox.rpy:452
translate chinese kenodox_c3af7dc3:

    # This "Как-то раз я уже пытался опустошить себе черепушку киркой. Конечно, Старший Смены меня остановил; но всё же приятно знать, что я мог бы ничего и не почувствовать."
    This "我以前曾试图用镐清空自己的颅骨。那次，轮班主管阻止了我。不过，知道我当时可能什么都感觉不到，还是挺好的。"

# game/code/text/text_hells_kenodox.rpy:453
translate chinese kenodox_8877d42a:

    # Kav "Как-нибудь в другой раз."
    Kav "改天吧。"

# game/code/text/text_hells_kenodox.rpy:455
translate chinese kenodox_c2874a48:

    # Bitt "Ты только скажи. Сможешь попробовать свои мысли на вкус."
    Bitt "你开口就行。要知道，你可以品尝自己的思想。"

# game/code/text/text_hells_kenodox.rpy:457
translate chinese kenodox_301b9e02:

    # Bitt "Сообщения от тела мозг принимает к сведению. И сам решает, какую степень важности им присвоить. Какую реакцию на сигнал вызвать."
    Bitt "大脑会考虑来自身体的信息。然后决定赋予它们的重要性等级。决定对信号的激发做出何种反应。"

# game/code/text/text_hells_kenodox.rpy:458
translate chinese kenodox_036a6c0a:

    # Kav "Ты так говоришь, как будто у него есть целый список степеней…"
    Kav "你说得好像它有一整张等级列表似的……"

# game/code/text/text_hells_kenodox.rpy:462
translate chinese kenodox_06aad9be:

    # Bitt "Да! Он есть! Мозг составляет этот список и хранит его в памяти. Оценивает реальную опасность, сверяясь со списком, и только после этого пропускает подходящий сигнал в сознание."
    Bitt "没错！确实有！大脑制定这份列表并储存在记忆中。它通过对照列表评估真实危险，然后才将相应的信号放入意识。"

# game/code/text/text_hells_kenodox.rpy:464
translate chinese kenodox_9a82cfc1:

    # Bitt "Чем больше переживаний и видов опасности ты испытал за свою жизнь — тем более полный этот список. Тем более интересной и разнообразной будет боль!"
    Bitt "你生命中的经历和危险类型越多，这份列表就越完整。疼痛就会越有趣、越多样！"

# game/code/text/text_hells_kenodox.rpy:465
translate chinese kenodox_4388da08:

    # This "Глаза Горечи разгорелись; по телу то и дело пробегала беспокойная дрожь. Пальцы судорожно сжимались, впиваясь в кожу так сильно, что из-под ногтей проступала тёмная кровь."
    This "苦涩的眼睛亮了起来；一阵不安的颤抖不时掠过她的身体。她的手指痉挛般地攥紧，深深抠进皮肤，以至于暗红的血液从指甲下渗了出来。"

# game/code/text/text_hells_kenodox.rpy:466
translate chinese kenodox_0de5edc8:

    # This "Лучше не показывать ей свой страх. Именно этого она и ждёт."
    This "最好不要让她看到我的恐惧。那正是她想要的。"

# game/code/text/text_hells_kenodox.rpy:468
translate chinese kenodox_6a0e986f:

    # Kav "Значит, мой мозг решил, что удар киркой — это низкая степень важности по сравнению с твоим порезом?"
    Kav "所以我的大脑认为，镐击的痛苦优先级低于你的割伤？"

# game/code/text/text_hells_kenodox.rpy:470
translate chinese kenodox_1685ee3c:

    # Bitt "О-о-о, мне было бы лестно, если бы это было так. Ты не можешь умереть, и поэтому боль от острия кирки невелика. Ты боишься меня, и поэтому мой порез оказался болезненным. Это показывает, насколько я важна для тебя."
    Bitt "呃哦，如果真是那样，我会感到荣幸。你死不了，所以镐击的疼痛很轻微。你害怕我，所以我的割伤才那么疼。这说明我对你很重要。"

# game/code/text/text_hells_kenodox.rpy:472
translate chinese kenodox_eea9bd9d:

    # Bitt "Но, к сожалению, дело в другом. В тот сладостный момент, когда ты решил зарезать сам себя, в тебе не было памяти об опасностях, переживаниях и подходящей к ним боли."
    Bitt "但是，可惜，情况并非如此。在你决定刺伤自己的那个美妙时刻，你还没有关于危险、经历以及相应疼痛的记忆。"

# game/code/text/text_hells_kenodox.rpy:473
translate chinese kenodox_a91f16fd:

    # Bitt "Поэтому подобрать подходящий сигнал для сознания мозг не смог. И выдал средненький, скучный укол."
    Bitt "因此，大脑无法为意识挑选出合适的信号。所以它只发出了一个平庸、乏味的冲击。"

# game/code/text/text_hells_kenodox.rpy:477
translate chinese kenodox_742e8b2b:

    # This "Не было памяти. Только с памятью пришли страдания. Горечь не врёт."
    This "没有记忆。痛苦是伴随着记忆一起来的。苦涩没有说谎。"

# game/code/text/text_hells_kenodox.rpy:478
translate chinese kenodox_98174bc8:

    # Kav "Почему ты говоришь мне правду?"
    Kav "你为什么要告诉我真相？"

# game/code/text/text_hells_kenodox.rpy:480
translate chinese kenodox_4b1afd88:

    # Bitt "Во лжи нет такого удовольствия."
    Bitt "说谎没有这种乐趣。"

# game/code/text/text_hells_kenodox.rpy:481
translate chinese kenodox_f04626b9:

    # Bitt "К тому же, я не могу лгать о своём занятии. Иначе я стану никем."
    Bitt "此外，我不能在我的职业上说谎。否则，我就会变成无名之辈。"

# game/code/text/text_hells_kenodox.rpy:483
translate chinese kenodox_ad06fb88:

    # Kav "Занятии? Всё-таки ты тоже работаешь, чтобы попасть в Град?"
    Kav "职业？所以你也在工作，为了进入诺伊堡？"

# game/code/text/text_hells_kenodox.rpy:485
translate chinese kenodox_e0149690:

    # Bitt "Я не тороплюсь в Град. Но здесь нужно иметь занятие, чтобы не превратиться в овоща."
    Bitt "我不急着去诺伊堡。但在这里，你总得做点什么，才不会变成一株蔬菜。"

# game/code/text/text_hells_kenodox.rpy:487
translate chinese kenodox_4fd20f4b:

    # Bitt "Здесь, внизу, из безмозглой людской массы выросло целое сообщество. А всем сообществам приходится рано или поздно доставать плети и стегать самых ленивых и тупых своих участников."
    Bitt "在这下面，一个完整的社群已经从无脑的人群中成长起来。而所有社群，迟早都得拿出鞭子，鞭打其中最懒惰、最愚蠢的成员。"

# game/code/text/text_hells_kenodox.rpy:489
translate chinese kenodox_ee60a868:

    # Bitt "Я и есть эта плеть."
    Bitt "我就是那根鞭子。"

# game/code/text/text_hells_kenodox.rpy:491
translate chinese kenodox_92c49979:

    # Bitt "Я — стимул. Разумность и осознанность всех остальных, низкое количество овощей — реакция."
    Bitt "我是刺激。其他人的理性和意识，蔬菜的低数量，就是反应。"

# game/code/text/text_hells_kenodox.rpy:492
translate chinese kenodox_bc666d26:

    # This "С какой же искренней гордостью она это говорит. Даже многочисленные пальцы прервали своё бесконечное путешествие по липкой и скользкой коже — словно прислушались к столь важным для неё словам."
    This "她说起这个时带着如此真诚的自豪。就连她那多根手指也停止了在黏滑皮肤上永无止境的游走，仿佛在聆听对她而言至关重要的话语。"

# game/code/text/text_hells_kenodox.rpy:493
translate chinese kenodox_c31330bd:

    # This "Всё это вызывает только злость."
    This "这一切只让我更加愤怒。"

# game/code/text/text_hells_kenodox.rpy:494
translate chinese kenodox_16ff4043:

    # Kav "Ты сама назначила себя палачом и мучителем. Ищешь новые способы стимуляции для собственного удовольствия. Лучше найди в себе смелость признать это в открытую."
    Kav "所以你自封为刽子手和折磨者。你为了自己的快感寻找新的刺激方式。不如鼓起勇气公开承认吧。"

# game/code/text/text_hells_kenodox.rpy:496
translate chinese kenodox_77351b04:

    # Bitt "О-о-о, нужно рассказать тебе больше о себе, чтобы ты мог язвить и насмехаться изощрённее."
    Bitt "哦哦哦，我需要多告诉你一些我的事，这样你才能更巧妙地讥讽和嘲笑。"

# game/code/text/text_hells_kenodox.rpy:498
translate chinese kenodox_cbf0c894:

    # Bitt "Но нет. Видишь ли, мозг, составляющий списки боли, является своеобразным… коллекционером. И я, в силу своей работы, являюсь коллекционером тоже."
    Bitt "但不行。你看，制定疼痛列表的大脑，是一种……收藏家。而我，由于我的工作，也是一名收藏家。"

# game/code/text/text_hells_kenodox.rpy:502
translate chinese kenodox_4207dd6b:

    # This "Она повела рукой в сторону, указывая на стену за бассейном."
    This "然后她指向水池后面的墙壁。"

# game/code/text/text_hells_kenodox.rpy:504
translate chinese kenodox_81a46fb8:

    # This "Только сейчас я осознал, что в полутьме ниш на этой стене скрываются не просто случайные кусочки плоти."
    This "直到现在我才意识到，这面墙壁壁龛的半明半暗中，并非只是随意摆放的肉块。"

# game/code/text/text_hells_kenodox.rpy:505
translate chinese kenodox_93e8ec45:

    # This "Это аккуратно разложенные органы. Живые и трепещущие в отчаянном поиске утраченных тел. В одной из ниш скрывается целая голова — измождённое лицо закрыло глаза и плотно сжало губы."
    This "那是整齐排列的器官。活着的，颤抖着，绝望地寻找着它们失去的身体。其中一个壁龛里藏着一整个头颅——一张憔悴的脸紧闭着眼睛，嘴唇也紧紧抿着。"

# game/code/text/text_hells_kenodox.rpy:506
translate chinese kenodox_debb9787:

    # Kav "Я думал, что ты коллекционируешь только пальцы."
    Kav "我以为你只收藏手指。"

# game/code/text/text_hells_kenodox.rpy:508
translate chinese kenodox_87bdcd60:

    # Bitt "Пальцы — это та часть коллекции, которую я ношу с собой."
    Bitt "手指是我随身携带的那部分收藏品。"

# game/code/text/text_hells_kenodox.rpy:512
translate chinese kenodox_80fe64fe:

    # Kav "А я? Тоже часть твоей коллекции? Очередная игрушка?"
    Kav "那我呢？我也是你收藏的一部分吗？又一个玩具？"

# game/code/text/text_hells_kenodox.rpy:513
translate chinese kenodox_3cb9b13d:

    # This "Как хорошо, что тут нет вездесущего плетения нервов и мышц под ногами. Некому трепетать от моей злости, некому впитывать и распространять мои чувства."
    This "幸好脚下没有无处不在的神经和肌肉网络。没有谁会因我的愤怒而颤抖，没有谁会吸收并扩散我的感受。"

# game/code/text/text_hells_kenodox.rpy:515
translate chinese kenodox_919926bf:

    # Bitt "М-м-м… Это зависит только от тебя. Думаю, скоро мы выясним, стимул ты или реакция. Движитель или инертная, движимая масса."
    Bitt "嗯哼……这取决于你。我想我们很快就会知道，你是刺激还是反应。是推动者，还是惰性的、被推动的质量。"

# game/code/text/text_hells_kenodox.rpy:516
translate chinese kenodox_1c91a1c7:

    # This "С меня хватит. Я покажу тебе, как я умею двигаться."
    This "我受够了。我会让你看看我能如何行动。"

# game/code/text/text_hells_kenodox.rpy:520
translate chinese kenodox_aaad663c:

    # This "Когда я рванул быстрым шагом к выходу из комнаты, мне вслед донёсся весёлый хохот."
    This "当我快速冲向房间出口时，身后传来了笑声。"

# game/code/text/text_hells_kenodox.rpy:521
translate chinese kenodox_2fe11948:

    # Bitt "И не смей останавливаться! Как только ты замрёшь, пусть даже на секунду, я настигну тебя!"
    Bitt "你敢停下试试！只要你僵住，哪怕一秒钟，我就会追上你！"

# game/code/text/text_hells_kenodox.rpy:523
translate chinese kenodox_d4dc92da:

    # This "Шлепки моих босых ступней по голому камню скакали наглым эхом по огромной пещере. Наверное, слишком наглым для этого места. Кто знает, кто или что ещё может меня услышать."
    This "我赤脚拍打光秃石头发出的声音，在这巨大的洞穴中放肆地回响。对这个地方来说，可能太放肆了。谁知道还有谁或什么东西会听到我。"

# game/code/text/text_hells_kenodox.rpy:524
translate chinese kenodox_0a3a3c66:

    # This "Но мне всё равно."
    This "但我不在乎。"

# game/code/text/text_hells_kenodox.rpy:525
translate chinese kenodox_54ed9581:

    # This "Я хочу в Град, но сам не знаю, зачем. Я хочу сбежать, но сам не знаю, от чего. Горечь права — я просто инертная масса, которую двигают импульсы боли и страха."
    This "我想去诺伊堡，却不知为何。我想逃离，却不知逃离什么。苦涩说得对——我只是一团惰性物质，被痛苦和恐惧的冲动驱使着。"

# game/code/text/text_hells_kenodox.rpy:526
translate chinese kenodox_73f7cdef:

    # This "Нужные мне ответы нависли тёмной и холодной глыбой памяти над трусливым разумом."
    This "我需要的答案，如同一块黑暗而冰冷的记忆块，悬浮在我怯懦的头脑之上。"

# game/code/text/text_hells_kenodox.rpy:527
translate chinese kenodox_4390cead:

    # This "Кто-то хотел освободить меня от этого груза; но ему не удалось довести дело до конца. Было ли это ошибкой? Какая из этих двух вещей была истинным наказанием?"
    This "有人想卸下我这个负担，但他们没能完成。这是个错误吗？这两件事中，哪一件才是真正的惩罚？"

# game/code/text/text_hells_kenodox.rpy:528
translate chinese kenodox_1ef1e440:

    # This "Погружённый в свои мысли, я чуть не врезался в тень, вдруг появившуюся из полутьмы."
    This "沉浸在深思中，我差点撞上一个从黑暗中突然出现的影子。"

# game/code/text/text_hells_kenodox.rpy:532
translate chinese kenodox_88e1e98d:

    # Dm "Ты слишком тощий для неё. Слишком слабый."
    Dm "你对她来说太瘦弱了。太虚弱了。"

# game/code/text/text_hells_kenodox.rpy:534
translate chinese kenodox_033cd71a:

    # Kav "Что?"
    Kav "什么？"

# game/code/text/text_hells_kenodox.rpy:536
translate chinese kenodox_eba28753:

    # Dm "Ты недостоин Горечи. Тебе не место рядом с ней."
    Dm "你不配得到苦涩。你不该和她在一起。"

# game/code/text/text_hells_kenodox.rpy:538
translate chinese kenodox_e59dbc97:

    # Kav "Ага. Да. Полностью согласен. Поэтому я от неё ухожу."
    Kav "是啊。是啊。我完全同意。所以我才要离开她。"

# game/code/text/text_hells_kenodox.rpy:540
translate chinese kenodox_ec1bfc75:

    # Dm "Никто не смеет уходить от неё по своей воле."
    Dm "没人敢凭自己的意愿离开她。"

# game/code/text/text_hells_kenodox.rpy:542
translate chinese kenodox_9cb2dee4:

    # Kav "Тут… кажется, тут возникает какое-то противоречие."
    Kav "这……似乎有点矛盾。"

# game/code/text/text_hells_kenodox.rpy:556
translate chinese kenodox_8e9b9f04:

    # This "Вместо ответа странный демон метнулся ко мне."
    This "那奇怪的恶魔没有回答，而是朝我猛扑过来。"

# game/code/text/text_hells_kenodox.rpy:557
translate chinese kenodox_b82a7f08:

    # This "Когтистая лапа стальным обручем охватила горло."
    This "一只利爪像铁箍一样缠住了我的脖子。"

# game/code/text/text_hells_kenodox.rpy:559
translate chinese kenodox_494a22d7:

    # Kav "К-х-ха…"
    Kav "呃啊……"

# game/code/text/text_hells_kenodox.rpy:583
translate chinese kenodox_4fb3def6:

    # This "Раздался лёгкий, удивительно обыденный треск — словно порвалась грубая ткань."
    This "传来一声轻微、出奇寻常的碎裂声，就像粗糙的布料被撕开。"

# game/code/text/text_hells_kenodox.rpy:584
translate chinese kenodox_50579b6f:

    # This "Хруст моих позвонков."
    This "是我脊椎断裂的嘎吱声。"

# game/code/text/text_hells_kenodox.rpy:585
translate chinese kenodox_7d036f05:

    # This "Я с ужасом ощутил, как немеющие ноги оторвались от земли."
    This "我惊恐地感到自己冻僵的双腿被提离了地面。"

# game/code/text/text_hells_kenodox.rpy:586
translate chinese kenodox_96d866b2:

    # Dm "Конфликт? В тебе нет сил для конфликта."
    Dm "矛盾？你连矛盾的力量都没有。"

# game/code/text/text_hells_kenodox.rpy:587
translate chinese kenodox_bcb1d3b6:

    # Dm "Горит ли твой разум так же, как твоё тело? Плавит ли этот вечный огонь тебя в нечто другое, нечто более твёрдое и прочное?"
    Dm "你的心灵是否也和身体一样在燃烧？这永恒之火是否将你熔炼成别的东西，更坚固、更持久的东西？"

# game/code/text/text_hells_kenodox.rpy:588
translate chinese kenodox_cf72e834:

    # Dm "Конечно же, нет."
    Dm "当然没有。"

# game/code/text/text_hells_kenodox.rpy:589
translate chinese kenodox_ea4e31fa:

    # Kav "От…пусти-х-х…"
    Kav "放……放开……"

# game/code/text/text_hells_kenodox.rpy:590
translate chinese kenodox_9c6a3580:

    # This "Его рука действительно тверда, как камень; само прикосновение к ней вызывает у меня чувство безнадёжности. Я не могу разжать даже один его палец."
    This "他的手真的硬如磐石。仅仅是触碰就让我感到绝望。我甚至无法掰开他一根手指。"

# game/code/text/text_hells_kenodox.rpy:591
translate chinese kenodox_c1eaef79:

    # Dm "Госпожа Горечь уничтожит тебя. Я же могу тебя освободить. Просто расслабься и сдайся."
    Dm "苦涩女主人会毁了你。而我，可以让你解脱。放松，放弃吧。"

# game/code/text/text_hells_kenodox.rpy:592
translate chinese kenodox_36d46127:

    # This "Похоже, этот идиот жаждет занять моё место в коллекции Горечи. И считает меня своим соперником."
    This "看来这个白痴急于在苦涩的收藏中取代我的位置。他以为我是他的情敌。"

# game/code/text/text_hells_kenodox.rpy:593
translate chinese kenodox_681ccb84:

    # This "Я задохнусь из-за глупого недопонимания."
    This "我要因为一个愚蠢的误会而窒息而死了。"

# game/code/text/text_hells_kenodox.rpy:598
translate chinese kenodox_064f0b1c:

    # This "Главкон с ними всеми. Пусть забирает себе свою драгоценную Горечь. Может быть, она не станет искать меня, пока будет резать его."
    This "去他们的。让他去拿他宝贵的苦涩吧。也许那样，她忙着切割他的时候，就不会来找我了。"

# game/code/text/text_hells_kenodox.rpy:599
translate chinese kenodox_9ccdc807:

    # This "Я перестал дёргаться и закрыл глаза."
    This "我停止了抽搐，闭上了眼睛。"

# game/code/text/text_hells_kenodox.rpy:603
translate chinese kenodox_9f44d64f:

    # This "Плевать мне на Горечь!.."
    This "我不在乎苦涩！……"

# game/code/text/text_hells_kenodox.rpy:604
translate chinese kenodox_1a9da068:

    # This "Меня злит его глупость. Меня злит его наглость."
    This "让我愤怒的是他的愚蠢。我愤怒于他的傲慢无礼。"

# game/code/text/text_hells_kenodox.rpy:605
translate chinese kenodox_e2913914:

    # This "Но больше всего меня злит слабость моего тела."
    This "但最让我愤怒的，是我身体的虚弱。"

# game/code/text/text_hells_kenodox.rpy:606
translate chinese kenodox_99516496:

    # This "Я с трудом сжал руку в рыхлый, дрожащий кулак, и попытался ударить демона в голову. Вместо этого только ушиб костяшки о загнутый рог."
    This "我费了很大劲，终于把手攥成一个松软、颤抖的拳头，试图打向恶魔的头。结果，我的指关节只是撞在了弯曲的角上。"

# game/code/text/text_hells_kenodox.rpy:608
translate chinese kenodox_5898478e:

    # Dm "Я же сказал. Ты не выдержишь и пары развлечений Горечи."
    Dm "我告诉过你。你承受不了苦涩的消遣。"

# game/code/text/text_hells_kenodox.rpy:609
translate chinese kenodox_fc8d344d:

    # Dm "Рядом с ней должен быть я."
    Dm "我才是该和她在一起的那个。"

# game/code/text/text_hells_kenodox.rpy:610
translate chinese kenodox_c20f5119:

    # This "Ну так пойди к ней сам, тупая кость!.."
    This "那你自己去找她啊，你这蠢骨头！……"

# game/code/text/text_hells_kenodox.rpy:611
translate chinese kenodox_78119d45:

    # This "Словно услышав мои мысли, он встряхнул меня как тряпку, вызвав ещё одну волну хруста позвонков."
    This "仿佛听到了我的心声，他像抖抹布一样摇晃我，又引起一阵脊椎的嘎吱作响。"

# game/code/text/text_hells_kenodox.rpy:634
translate chinese kenodox_a87a924b:

    # Dm "Неужели она настолько поработила тебя? Очнись! Ты раб, а она плеть!"
    Dm "她就这样奴役了你吗？醒醒！你是奴隶，而她就是鞭子！"

# game/code/text/text_hells_kenodox.rpy:639
translate chinese kenodox_064f0b1c_1:

    # This "Главкон с ними всеми. Пусть забирает себе свою драгоценную Горечь. Может быть, она не станет искать меня, пока будет резать его."
    This "去他们的。让他去拿他宝贵的苦涩吧。也许那样，她忙着切割他的时候，就不会来找我了。"

# game/code/text/text_hells_kenodox.rpy:640
translate chinese kenodox_9ccdc807_1:

    # This "Я перестал дёргаться и закрыл глаза."
    This "我停止了抽搐，闭上了眼睛。"

# game/code/text/text_hells_kenodox.rpy:644
translate chinese kenodox_34afcb5c:

    # This "Глупо было с его стороны называть меня рабом. А ведь я уже почти решил сдаться."
    This "他叫我奴隶真是愚蠢。而我差点就要放弃了。"

# game/code/text/text_hells_kenodox.rpy:645
translate chinese kenodox_b6662600:

    # This "Закипевшая от злости кровь бросилась в лицо. Стало так жарко, что я удивился, не увидев пара от своего дыхания."
    This "我的血液因愤怒而沸腾，涌上脸庞。热得让我惊讶自己呼出的气竟然没有冒蒸汽。"

# game/code/text/text_hells_kenodox.rpy:646
translate chinese kenodox_15dcbd54:

    # Dm "Я чувствую твой гнев. Может быть, я ошибался. Может быть, в тебе есть вечный пожар."
    Dm "我感受到了你的愤怒。也许我错了。也许你体内真有永恒之火。"

# game/code/text/text_hells_kenodox.rpy:647
translate chinese kenodox_819d9429:

    # Dm "Теперь я тем более не могу тебя отпустить."
    Dm "现在我更不能放你走了。"

# game/code/text/text_hells_kenodox.rpy:649
translate chinese kenodox_df37465a:

    # This "Хватка на горле усилилась. В глазах потемнело."
    This "掐住我喉咙的手收紧了。眼前一片漆黑。"

# game/code/text/text_hells_kenodox.rpy:650
translate chinese kenodox_9f984910:

    # This "Как же близка желанная пустота. Только руку протяни — и перестанешь существовать. Опять."
    This "我现在离渴望的空虚如此之近。只要再多一点，我就不复存在了。再一次。"

# game/code/text/text_hells_kenodox.rpy:651
translate chinese kenodox_cc946c9a:

    # This "Я же так этого хотел."
    This "毕竟，那正是我想要的。"

# game/code/text/text_hells_kenodox.rpy:652
translate chinese kenodox_e4f1b458:

    # This "Почему на глазах слёзы злости и обиды? Почему кровь на искусанных губах?"
    This "那为什么我眼中还有愤怒和怨恨的泪水？为什么我咬破的嘴唇上还有血？"

# game/code/text/text_hells_kenodox.rpy:653
translate chinese kenodox_3af30e7f:

    # This "Глупый Джосайя. Не хочет отдыхать. Притащил за собой всю свою жизнь, и тычет теперь её под нос, как какую-то ценность."
    This "愚蠢的约西亚。他不想安息。他拖着他的一生不放，现在又把它塞到我鼻子底下，好像是什么宝贵的东西。"

# game/code/text/text_hells_kenodox.rpy:654
translate chinese kenodox_b495fac8:

    # This "Поймал момент моей слабости и теперь торопливо пихает память мне в пасть."
    This "他抓住了我虚弱的瞬间，现在正匆忙地把记忆塞进我嘴里。"

# game/code/text/text_hells_kenodox.rpy:655
translate chinese kenodox_9261f896:

    # This "Я не выдерживаю и глотаю."
    This "而我无法抗拒，只能咽下。"

# game/code/text/text_hells_kenodox.rpy:658
translate chinese kenodox_f5bac056:

    # This "Я помню. Помню, откуда пришёл."
    This "我想起来了。我记得我从哪里来。"

# game/code/text/text_hells_kenodox.rpy:659
translate chinese kenodox_6ccdc944:

    # This "Город, равнодушно смахнувший меня в этот ад. Словно я всего лишь мусор."
    This "那个冷漠地将我扫入这个地狱的城市。仿佛我不过是垃圾。"

# game/code/text/text_hells_kenodox.rpy:662
translate chinese kenodox_7ce36bed:

    # This "Помню, как здесь очутился."
    This "我记得我是怎么来到这里的。"

# game/code/text/text_hells_kenodox.rpy:663
translate chinese kenodox_192791e4:

    # This "Страдания, которым позавидует сама Горечь. Наказание, которого я не заслужил."
    This "连苦涩本身都会嫉妒的痛苦。我不应承受的惩罚。"

# game/code/text/text_hells_kenodox.rpy:665
translate chinese kenodox_3c45a144:

    # This "…"
    This "……"

# game/code/text/text_hells_kenodox.rpy:666
translate chinese kenodox_974f67f6:

    # This "Ну уж нет."
    This "绝不。"

# game/code/text/text_hells_kenodox.rpy:667
translate chinese kenodox_b7b954ad:

    # This "Давай же, убогое тело!.. Я не инертная масса!"
    This "动起来，你这可悲的身体！……我不是一团惰性物质！"

# game/code/text/text_hells_kenodox.rpy:669
translate chinese kenodox_aeef0eb9:

    # This "Я почувствовал шевеление в спине. Медленно и упрямо позвонки поползли на свои места. Вспышкой боли отозвались конечности, вернувшиеся под мой контроль."
    This "我感到我的背在动。缓慢而顽固地，脊椎爬回了原位。一阵剧痛闪过我的四肢，它们重新回到了我的控制之下。"

# game/code/text/text_hells_kenodox.rpy:671
translate chinese kenodox_290085fe:

    # This "Вместе с болью пришло понимание, что глупый здесь всё ещё я. Просто использовал не ту руку."
    This "伴随着疼痛而来的，是我意识到自己仍然是这里愚蠢的那个。我只是用错了手。"

# game/code/text/text_hells_kenodox.rpy:675
translate chinese kenodox_774dee1f:

    # This "Привычный, отработанный замах, впитавшийся в мышцы и кости. Раз-два."
    This "一个熟悉的、千锤百炼的挥击，已融入肌肉和骨骼。一、二。"

# game/code/text/text_hells_kenodox.rpy:678
translate chinese kenodox_3c31fd47:

    # This "Привычный свист лезвия. Привычное чавканье плоти."
    This "熟悉的刀刃破风声。熟悉的皮肉撕裂声。"

# game/code/text/text_hells_kenodox.rpy:679
translate chinese kenodox_d4e88638:

    # This "Норма Выработки будет довольна."
    This "生产配额将得到满足。"

# game/code/text/text_hells_kenodox.rpy:681
translate chinese kenodox_c4c2d162:

    # This "Колени больно врезались в камень."
    This "我的膝盖撞在石头上生疼。"

# game/code/text/text_hells_kenodox.rpy:683
translate chinese kenodox_a56088b9:

    # This "Рядом глухо стукнуло упавшее тело. Чужое тело."
    This "一具倒下的身体在旁边砰然落地。别人的身体。"

# game/code/text/text_hells_kenodox.rpy:690
translate chinese kenodox_f35dc3a3:

    # This "Как же приятно видеть его изумлённую рожу. Сделать бы это ещё разок."
    This "看到他惊愕的脸真是太好了。我真想再来一次。"

# game/code/text/text_hells_kenodox.rpy:691
translate chinese kenodox_b01e1e37:

    # Dm "Г-глупец… За такое тебя сокрушат… Повергнут в прах…"
    Dm "蠢……货……为了这种事，你会被碾碎……你会被抛入尘土……"

# game/code/text/text_hells_kenodox.rpy:692
translate chinese kenodox_ed2b61a5:

    # Kav "Как ты говоришь? Чтобы говорить, нужны лёгкие."
    Kav "你怎么还能说话？说话需要肺。"

# game/code/text/text_hells_kenodox.rpy:693
translate chinese kenodox_8cd95ab1:

    # This "Молчание в ответ."
    This "回应的是沉默。"

# game/code/text/text_hells_kenodox.rpy:694
translate chinese kenodox_9ea86c07:

    # This "Его слова мне почудились? Неудивительно. Моя собственная голова чудом держится на плечах, похрустывая смятым горлом при каждом вдохе."
    This "我刚才听到他说那些话了？难怪。我自己的头还安在肩膀上才是个奇迹，每次呼吸都伴随着被掐扁的喉咙发出的嘎吱声。"

# game/code/text/text_hells_kenodox.rpy:695
translate chinese kenodox_6d04c423:

    # This "Но он прав. Эту голову найдут. Прирастить её к каким-нибудь лёгким — дело нескольких минут."
    This "但他说得对。他们会找到这个头。然后只需要几分钟就能把它接到某个肺上。"

# game/code/text/text_hells_kenodox.rpy:696
translate chinese kenodox_92768b41:

    # This "И после этого он расскажет всё."
    This "之后，他就会说出一切。"

# game/code/text/text_hells_kenodox.rpy:697
translate chinese kenodox_b7433212:

    # This "Какое наказание здесь грозит тем, кто напал на демона?"
    This "在这里，攻击恶魔会有什么惩罚？"

# game/code/text/text_hells_kenodox.rpy:698
translate chinese kenodox_b3af8ac0:

    # This "Можно измолотить эту голову в кашу и сожрать…"
    This "我可以把那颗头磨成糊然后吃掉……"

# game/code/text/text_hells_kenodox.rpy:699
translate chinese kenodox_f77c1c61:

    # This "Привычная мысль для обитателя этих мест. Но где-то внутри, на задворках сознания, кричал от ужаса вернувший себе память Джосайя."
    This "对这些地方的居民来说，这是个熟悉的想法。但在内心深处，在我脑海的角落，恢复了记忆的约西亚在恐惧地尖叫。"

# game/code/text/text_hells_kenodox.rpy:700
translate chinese kenodox_f77bdc85:

    # This "Это место чудовищно. Я чудовище."
    This "这个地方是怪物。我也是怪物。"

# game/code/text/text_hells_kenodox.rpy:701
translate chinese kenodox_9a12e39e:

    # This "Сейчас не время, чтобы трястись от страха."
    This "但现在不是害怕得发抖的时候。"

# game/code/text/text_hells_kenodox.rpy:702
translate chinese kenodox_18f3e8b6:

    # This "Может быть, удастся спрятать жуткую улику… Но где?"
    This "也许可以藏起这可怕的证据……但藏在哪里？"

# game/code/text/text_hells_kenodox.rpy:706
translate chinese kenodox_7df85b17:

    # This "Заметит ли Горечь, если я подменю одну голову в её коллекции на другую?"
    This "如果我调换她收藏中的一个头，苦涩会注意到吗？"

# game/code/text/text_hells_kenodox.rpy:707
translate chinese kenodox_f63c989e:

    # This "Выбора нет. Стоит попробовать."
    This "没有别的选择了。值得一试。"

# game/code/text/text_hells_kenodox.rpy:711
translate chinese kenodox_2152abac:

    # This "В шахтах можно найти укромное место. В крайнем случае, можно пожертвовать её Зобу."
    This "在矿洞里，我能找到一个隐蔽的地方。至少，我可以把它交给甲瘤。"

# game/code/text/text_hells_kenodox.rpy:712
translate chinese kenodox_a40c6821:

    # Kav "Ты ведь не будешь больше разговаривать или кусаться, верно?.."
    Kav "你不会再说话或咬人了吧？"

# game/code/text/text_hells_kenodox.rpy:714
translate chinese kenodox_9d2cb5af:

    # This "Я встал, осторожно удерживая голову демона за ребристый рог."
    This "我站起来，小心翼翼地抓着恶魔那带肋骨的角提着他的头。"

# game/code/text/text_hells_kenodox.rpy:715
translate chinese kenodox_bc6294b9:

    # This "Как же хочется подкинуть её и пнуть изо всех сил, как мячик. Но тогда я сломаю себе лодыжку."
    This "我恨不得把它抛起来，然后像踢球一样用尽全力踢一脚。但那样我的脚踝会断掉。"

# game/code/text/text_hells_kenodox.rpy:716
translate chinese kenodox_14b51909:

    # This "Вместо этого я перехватил рог поудобнее и торопливо зашагал обратно в пещеры."
    This "相反，我抓住角，匆忙返回洞穴方向。"

# game/code/text/text_hells_kenodox.rpy:722
translate chinese kenodox_55bf1f46:

    # This "Скользкий от крови рог выворачивается из руки. Проще было бы насадить отрубленную голову на кирку."
    This "沾满血的角滑溜溜的，总想从我手里滑脱。要是能把头插在我的十字镐上就方便多了。"

# game/code/text/text_hells_kenodox.rpy:723
translate chinese kenodox_a025afd0:

    # Head "Слабый трус… Боишься даже взглянуть на меня. Тебя заменят мною."
    Head "你这懦弱的废物……你连看都不敢看我。我会取代你的。"

# game/code/text/text_hells_kenodox.rpy:724
translate chinese kenodox_837199e4:

    # Kav "Ты не можешь говорить. Уймись."
    Kav "（卡维亚尼）你不能说话。闭嘴。"

# game/code/text/text_hells_kenodox.rpy:725
translate chinese kenodox_505085ee:

    # Head "Тем лучше. Значит, это ты говоришь себе сам."
    Head "（头目）那更好。这可是你自己说的。"

# game/code/text/text_hells_kenodox.rpy:726
translate chinese kenodox_2222a554:

    # Kav "Замолчи. Мне и без тебя хватает голосов в голове."
    Kav "（卡维亚尼）闭嘴。我脑子里的声音够多了。"

# game/code/text/text_hells_kenodox.rpy:728
translate chinese kenodox_233f24ab:

    # This "Теперь я помню, почему эта каморка показалась такой знакомой. Она почти такого же размера, как моя комната в проклятом Городе."
    This "现在我明白为什么这个房间如此眼熟了。它几乎和我在那座诅咒之城的房间一样大。"

# game/code/text/text_hells_kenodox.rpy:729
translate chinese kenodox_47271e46:

    # This "Уродливое и кошмарное отражение моей прошлой жизни. Даже голос верного Бомануара тут заменён на ужасающий шёпот живых стен."
    This "是我过去生活丑陋而噩梦般的倒影。就连忠实的博马努瓦的声音，也被活体墙壁那可怕的低语所取代。"

# game/code/text/text_hells_kenodox.rpy:730
translate chinese kenodox_5ad16c58:

    # This "Заменён ли?.. Какие ещё тайны могут скрываться за бетонными стенами Города?"
    This "真的被取代了吗？……这座城市混凝土墙壁的背后，还潜藏着什么其他秘密？"

# game/code/text/text_hells_kenodox.rpy:734
translate chinese kenodox_02328f54:

    # Bitt "Как быстро ты понял, что тебе некуда больше идти."
    Bitt "（苦涩）你这么快就意识到自己无处可去了。"

# game/code/text/text_hells_kenodox.rpy:736
translate chinese kenodox_0c6a46ab:

    # Bitt "Знакомые и привычные страдания лучше, чем страх неизвестности, правда? Боль тратит не так уж много энергии. А вот переживания о неопределённом будущем… Они высасывают тебя досуха."
    Bitt "（苦涩）熟悉的痛苦总好过对未知的恐惧，对吧？痛苦不怎么耗费精力。但为不确定的未来担忧……那会把你榨干。"

# game/code/text/text_hells_kenodox.rpy:738
translate chinese kenodox_a21395dd:

    # This "Только сейчас я понял, насколько же скрипучий у неё голос."
    This "直到此刻，我才意识到她的声音是多么刺耳。"

# game/code/text/text_hells_kenodox.rpy:739
translate chinese kenodox_ab017e69:

    # This "Словно скрежет сломанных костей."
    This "就像碎骨头在摩擦。"

# game/code/text/text_hells_kenodox.rpy:740
translate chinese kenodox_dea26619:

    # Kav "Я нашёл тебе подарок в коллекцию. Совсем свежая голова. Поэтому решил вернуться ненадолго."
    Kav "（卡维亚尼）我给你的收藏带了件礼物。是个新鲜的头颅。所以我决定回来一趟。"

# game/code/text/text_hells_kenodox.rpy:742
translate chinese kenodox_ca71b159:

    # Bitt "М-м… Мне очень приятно, правда. Но всё же не стоило. Раздобыть что-то интересное непросто, когда вокруг тысячи и тысячи желающих пожертвовать часть себя. Так что впредь лучше сперва спрашивай, что мне нужно."
    Bitt "（苦涩）嗯……确实很令人高兴。但你不必如此。当成千上万的人都愿意捐献自己的一部分时，想弄到有趣的东西可不容易。所以从今往后，你最好先问问我想要什么。"

# game/code/text/text_hells_kenodox.rpy:744
translate chinese kenodox_b1b4fc59:

    # Bitt "Но я всегда рада новым пальцам. У тебя есть пять лишних… Будет очень мило, если ты оторвёшь их себе сам."
    Bitt "（苦涩）不过收到新手指我总是很开心。你还有五根多余的……要是你能自己把它们扯下来就好了。"

# game/code/text/text_hells_kenodox.rpy:746
translate chinese kenodox_efa5f859:

    # This "Джосайя может сколько угодно кричать от ужаса, сколько угодно биться о стенки черепа изнутри. Но теперь я понимаю — это не угроза. Горечь не желает мне зла."
    This "约西亚可以尽情恐惧地尖叫。他可以从内部尽情撞击自己颅骨的内壁。但我现在明白了，这不是威胁。苦涩并不想伤害我。"

# game/code/text/text_hells_kenodox.rpy:747
translate chinese kenodox_74005219:

    # This "Здесь нет наставников, исповедников и Исправителей Внутренних Неполадок."
    This "这里没有导师，没有告解师，也没有内心修正者。"

# game/code/text/text_hells_kenodox.rpy:748
translate chinese kenodox_49430bf4:

    # This "Впрочем, может, и есть. Но теперь они терзают плоть, а не разум."
    This "或许其实是有的。只不过现在他们折磨的是肉体，而非心灵。"

# game/code/text/text_hells_kenodox.rpy:749
translate chinese kenodox_92087d98:

    # This "Некому указывать на греховность получения лишней порции эндорфинов через боль. Да и есть ли тут само понятие греха? Нет ничего дальше от Благодати и Любви, чем это место."
    This "没有人会指出通过痛苦获取额外内啡肽的罪孽。而在这里，真的有‘罪孽’这个概念吗？没有比这地方离慈爱恩典更远的了。"

# game/code/text/text_hells_kenodox.rpy:750
translate chinese kenodox_96740e73:

    # This "Через страдания удовольствие; через боль освобождение, пусть только на краткий миг действия гормонов. Здешним обитателям не доступны другие варианты. Их лишили свободы выбирать."
    This "通过受苦获得快感。通过疼痛获得自由。哪怕只是荷尔蒙作用的短暂瞬间。此地的居民别无选择。他们被剥夺了选择的自由。"

# game/code/text/text_hells_kenodox.rpy:751
translate chinese kenodox_7cf8886c:

    # This "В этом неестественном мире сами чувства искажены и перевёрнуты с ног на голову."
    This "在这个非自然的世界里，感觉本身也被扭曲、颠倒，从头到脚。"

# game/code/text/text_hells_kenodox.rpy:752
translate chinese kenodox_a110ebd2:

    # This "Кстати, о голове…"
    This "说到头……"

# game/code/text/text_hells_kenodox.rpy:753
translate chinese kenodox_31863b14:

    # Kav "Не стоило? Разве голова — это не ценная часть тела?"
    Kav "（卡维亚尼）所以你不想要？头颅不是身体宝贵的部分吗？"

# game/code/text/text_hells_kenodox.rpy:755
translate chinese kenodox_3e555a09:

    # Bitt "Не для меня. У каждого должны быть свои границы приличий. Чужие воспоминания отвратительны."
    Bitt "（苦涩）对我来说不是。每个人都该有自己的体面界限。别人的记忆令人作呕。"

# game/code/text/text_hells_kenodox.rpy:757
translate chinese kenodox_c9ebe9b8:

    # Bitt "Тем более, что у меня уже есть три штуки."
    Bitt "（苦涩）尤其是我已经有三颗了。"

# game/code/text/text_hells_kenodox.rpy:759
translate chinese kenodox_210a89de:

    # Kav "Три?.."
    Kav "（卡维亚尼）三颗？……"

# game/code/text/text_hells_kenodox.rpy:761
translate chinese kenodox_8b52652f:

    # Bitt "Твоя, моя и та, что на полке."
    Bitt "（苦涩）你的，我的，还有架子上的那颗。"

# game/code/text/text_hells_kenodox.rpy:763
translate chinese kenodox_942bc80c:

    # This "Неожиданное осложнение."
    This "一个意外的麻烦。"

# game/code/text/text_hells_kenodox.rpy:765
translate chinese kenodox_7a6b2c5e:

    # Kav "Как тут можно избавиться от мусора?"
    Kav "（卡维亚尼）你们这里怎么处理垃圾？"

# game/code/text/text_hells_kenodox.rpy:767
translate chinese kenodox_b6bd9582:

    # Bitt "Просто брось его в бассейн."
    Bitt "（苦涩）扔进池子里就行。"

# game/code/text/text_hells_kenodox.rpy:769
translate chinese kenodox_e786a755:

    # Kav "Что?.."
    Kav "（卡维亚尼）什么？……"

# game/code/text/text_hells_kenodox.rpy:770
translate chinese kenodox_a5ebf788:

    # Bitt "Всё ненужное растворяется, впитывается Плёнкой и уходит в Град."
    Bitt "（苦涩）一切不需要的东西都会被溶解，被膜吸收，然后进入伯格。"

# game/code/text/text_hells_kenodox.rpy:772
translate chinese kenodox_f63b2ab8:

    # Bitt "Я же сказала тебе, что ты попадёшь в Град, когда наскучишь мне. Надеюсь, ты ценишь мою честность."
    Bitt "（苦涩）我告诉过你，等我厌倦了你，你就会去伯格。希望你欣赏我的诚实。"

# game/code/text/text_hells_kenodox.rpy:774
translate chinese kenodox_e684e0d8:

    # Kav "Но зачем, почему? Я…"
    Kav "（卡维亚尼）但是为什么，为什么？我……"

# game/code/text/text_hells_kenodox.rpy:775
translate chinese kenodox_2f7702bd:

    # This "Не стоит раскрывать ей, что я что-то вспомнил. Пусть ей отвратительны чужие воспоминания, но здесь никогда не угадаешь. Может быть, она приходит в восторг от отвратительного."
    This "我不该向她透露我想起了什么。她或许厌恶别人的记忆，但在这里你永远无法确定。也许她其实就欣赏令人作呕的东西。"

# game/code/text/text_hells_kenodox.rpy:776
translate chinese kenodox_c97cf606:

    # Kav "…я не понимаю."
    Kav "（卡维亚尼）……我不明白。"

# game/code/text/text_hells_kenodox.rpy:778
translate chinese kenodox_65b54043:

    # Bitt "Разве? Мне всегда казалось, что это очевидно. Уж тебе-то, бывшему шахтёру, это должно быть понятно и близко до самого костного мозга."
    Bitt "（苦涩）是吗？我一直以为这很明显。作为前矿工，你比谁都该知道。"

# game/code/text/text_hells_kenodox.rpy:780
translate chinese kenodox_a93845c8:

    # Bitt "Шахтёры кормят Зоба. Зоб кормит шахтёров."
    Bitt "（苦涩）矿工喂养甲瘤。甲瘤喂养矿工。"

# game/code/text/text_hells_kenodox.rpy:781
translate chinese kenodox_60c687d4:

    # Bitt "Град кормит Плёнку. Плёнка кормит Град."
    Bitt "（苦涩）伯格喂养膜。膜喂养伯格。"

# game/code/text/text_hells_kenodox.rpy:783
translate chinese kenodox_70c5aa95:

    # Bitt "Удобная и устойчивая система. Малое повторяется в большом. Не удивлюсь, если союз Плёнки и Града кормит кого-то ещё. Нечто большее. Настолько большое, что мы не способны его увидеть."
    Bitt "（苦涩）一个简单而稳定的系统。小处在大处重现。如果膜和伯格的结合体也在喂养别的什么，我也不会惊讶。某个大得多的东西。大到我们甚至无法看见的东西。"

# game/code/text/text_hells_kenodox.rpy:785
translate chinese kenodox_9d6cde16:

    # This "По обнажённым позвонкам спины пробежалась дрожь."
    This "一阵战栗沿着我暴露的脊椎骨传下。"

# game/code/text/text_hells_kenodox.rpy:786
translate chinese kenodox_6f9ce913:

    # This "Вот так просто и обыденно я получил ответ на тот вопрос, из-за которого всё началось. Из-за которого я в итоге и оказался здесь."
    This "我就这样简单而随意地得到了那个引发一切的问题的答案。这就是我最初来到此地的原因。"

# game/code/text/text_hells_kenodox.rpy:787
translate chinese kenodox_ae197ed7:

    # This "Никаких скрытых баз наверху, ничего Машины не выращивают под Чистым Небом и Ярким Солнцем. Реальность оказалась гораздо проще и гораздо страшней."
    This "楼上没有什么隐藏基地，慈爱恩典之机在澄澈天空和明亮阳光下也没有培育任何东西。现实要简单得多，也恐怖得多。"

# game/code/text/text_hells_kenodox.rpy:788
translate chinese kenodox_23f65894:

    # This "Издевательски перевёрнутое и вывернутое наизнанку стремление людей выйти к Солнцу. Вместо того, чтобы двигаться вверх, Город прогрызается только вниз."
    This "人们渴望到外面阳光下，这个愿望被嘲弄般地扭曲、内外翻转。城市非但没有向上发展，反而只是向下啃噬。"

# game/code/text/text_hells_kenodox.rpy:789
translate chinese kenodox_f3b304b4:

    # This "Врастает своей плотью в камень, чтобы освободить место для новой плоти. Чем больше людей наверху — тем больше становится этот Ад внизу."
    This "它将血肉长进石头里，为新的血肉腾出空间。上层的人越多，下方的这个地狱就变得越大。"

# game/code/text/text_hells_kenodox.rpy:790
translate chinese kenodox_dcac0a36:

    # Kav "Аха-ха… Кха-ха…"
    Kav "（卡维亚尼）啊哈哈……哈哈哈……"

# game/code/text/text_hells_kenodox.rpy:791
translate chinese kenodox_dfd8d0d4:

    # This "Смешно. Старший Смены оказался прав, пусть и перепутал местами слова. Чем лучше там — тем хуже здесь."
    This "真是可笑。工头终究是对的。尽管他把措辞搞混了。上面越好，下面就越糟。"

# game/code/text/text_hells_kenodox.rpy:792
translate chinese kenodox_e26c5fae:

    # This "Местные обитатели постоянно говорят мне правду, и от этого становится только страшнее."
    This "本地人不断告诉我真相，而这只会让事情更可怕。"

# game/code/text/text_hells_kenodox.rpy:794
translate chinese kenodox_2a4d3370:

    # Bitt "Ты выглядишь расстроенным. Прости, что не приняла твой подарок. Думаю, если выловить его из бассейна поскорее, то ещё можно…"
    Bitt "（苦涩）你看起来很难过。抱歉我没收下你的礼物。我想如果我快点把他从池子里捞出来，或许还能……"

# game/code/text/text_hells_kenodox.rpy:796
translate chinese kenodox_771e4d4b:

    # Kav "Нет-нет, всё в порядке."
    Kav "（卡维亚尼）不，不，一切都好。"

# game/code/text/text_hells_kenodox.rpy:797
translate chinese kenodox_6a74f6a1:

    # This "Какие привычные слова. Заученная с детства фраза: «Всё в порядке»."
    This "多么熟悉的话语。一句自幼学会的话：“一切都好。”"

# game/code/text/text_hells_kenodox.rpy:798
translate chinese kenodox_696ce2c9:

    # This "Только сам порядок оказался безумным."
    This "只是这“一切”本身，结果却完全疯了。"

# game/code/text/text_hells_kenodox.rpy:799
translate chinese kenodox_381ec6ac:

    # Kav "Но ведь ты никого не кормишь. Что-то я не вижу в этой системе места для тебя и других д-дем…"
    Kav "（卡维亚尼）但你不喂养任何人。我看不出这个系统里有你和其它恶……魔的位置。"

# game/code/text/text_hells_kenodox.rpy:801
translate chinese kenodox_b251746e:

    # Bitt "Кто-то должен делать вид, что всё под контролем. Даже когда контроль не требуется вовсе."
    Bitt "（苦涩）总得有人假装一切尽在掌控。即便在根本不需要掌控的时候。"

# game/code/text/text_hells_kenodox.rpy:803
translate chinese kenodox_b7874165:

    # Bitt "Люди очень любят иерархию. Очень любят строить пирамиду и ставить на верхушку трон."
    Bitt "（苦涩）人们非常喜欢等级制度。他们喜欢建造金字塔，并在顶端放一把王座。"

# game/code/text/text_hells_kenodox.rpy:805
translate chinese kenodox_17cbdf76:

    # Bitt "А когда есть трон — кто-то должен в нём сидеть."
    Bitt "（苦涩）而有了王座，就得有人坐在上面。"

# game/code/text/text_hells_kenodox.rpy:806
translate chinese kenodox_018971e1:

    # Bitt "Зрелище пустого сиденья вызывает у нас дискомфорт. Словно зияющая дыра на месте вырванного зуба."
    Bitt "（苦涩）空着的座位会让我们感到不适。就像拔掉牙齿后留下的空洞。"

# game/code/text/text_hells_kenodox.rpy:808
translate chinese kenodox_cbbb631f:

    # This "Как уверенно она об этом рассуждает. На любой вопрос у неё есть готовый ответ."
    This "她说得多么自信。对任何问题都有现成的答案。"

# game/code/text/text_hells_kenodox.rpy:809
translate chinese kenodox_b91d3cb1:

    # This "Интересно, в каком Министерстве она сидела до того, как попала сюда. Скольких чиновников довела до отчаяния своими пытками."
    This "我好奇她在来到这里之前，是在哪个部门工作。她用她的折磨把多少官员逼到了绝望的境地。"

# game/code/text/text_hells_kenodox.rpy:810
translate chinese kenodox_f222312a:

    # Kav "Но когда-то мир был совсем другим! Как мы пришли к этому? Я не верю, что эта система сложилась сама, естественным образом!"
    Kav "（卡维亚尼）但曾经，世界完全不同！我们怎么会变成这样？我不相信这个系统是自行、自然地产生的！"

# game/code/text/text_hells_kenodox.rpy:812
translate chinese kenodox_92186ec2:

    # Bitt "Ску-у-учно."
    Bitt "（苦涩）无聊。"

# game/code/text/text_hells_kenodox.rpy:813
translate chinese kenodox_a532862e:

    # Bitt "Все эти философские рассуждения… Откуда мы пришли, куда идём? Я уже сказала тебе, это не имеет ни смысла, ни цели. Это просто жизнь."
    Bitt "（苦涩）所有这些哲学思辨……我们从哪里来？要到哪里去？我已经告诉过你了。这没有意义或目的。这只是生活。"

# game/code/text/text_hells_kenodox.rpy:815
translate chinese kenodox_d50f2ed5:

    # Bitt "Лучше покажи мне наконец, как ты убиваешь себя. Я всё ещё не могу понять, как ты смог вывернуть руку из сустава…"
    Bitt "（苦涩）你不如给我看看你是怎么试图自杀的。我还是想不通你怎么能把胳膊扭脱臼……"

# game/code/text/text_hells_kenodox.rpy:817
translate chinese kenodox_b98c92e2:

    # Kav "Покажу. Покажу что угодно, если всё объяснишь и ответишь на мои вопросы."
    Kav "（卡维亚尼）我会给你看的。只要你解释一切并回答我所有问题，你想看什么我都给你看。"

# game/code/text/text_hells_kenodox.rpy:819
translate chinese kenodox_74c14e8c:

    # Bitt "О-о-о, мучение через отказ, да-а? Как ты жесток. Используешь моё нетерпение против меня. Спасибо за это редкое ощущение. Мало кому хватает смелости мне отказывать."
    Bitt "（苦涩）哦，用拒绝来折磨我，是吧？你真坏。利用我的不耐烦来对付我。谢谢你带来这种难得的感受。很少有人有勇气对我说不。"

# game/code/text/text_hells_kenodox.rpy:821
translate chinese kenodox_4a3566a8:

    # Bitt "Тем интереснее мучение, ведь я не могу тебе ответить. Я не знаю, как мы пришли к этому. И это, как обычно, чистая правда."
    Bitt "（苦涩）这折磨更令人兴奋了，因为我无法回答你。我不知道我们怎么会变成这样。而这，一如既往，就是朴素的真相。"

# game/code/text/text_hells_kenodox.rpy:822
translate chinese kenodox_5e2aadb3:

    # This "Чёрт. Чёрт, чёрт!"
    This "该死。该死，真该死！"

# game/code/text/text_hells_kenodox.rpy:823
translate chinese kenodox_ca1feab0:

    # This "Чем ближе я подхожу к цели, тем дальше она отодвигается. Снова и снова."
    This "我离目标越近，它就离我越远。一次又一次。"

# game/code/text/text_hells_kenodox.rpy:824
translate chinese kenodox_22b53ac7:

    # This "Я должен докопаться до источника этого безумия. Должен вырвать корень зла, остановить круговорот страданий. Или хотя бы выбраться из него самому."
    This "我必须找到这疯狂的源头。我必须拔除邪恶的根源，停止这痛苦的循环。或者至少，我自己要从中脱身。"

# game/code/text/text_hells_kenodox.rpy:825
translate chinese kenodox_e569ef3b:

    # This "А после этого я доберусь до тех, кто отправил меня сюда. И тогда кирка мне пригодится."
    This "然后，我要去找那些把我送到这里来的人。到时候，十字镐就能派上用场了。"

# game/code/text/text_hells_kenodox.rpy:827
translate chinese kenodox_11781666:

    # Bitt "Но я могу отвести тебя к тому, кто знает. Или делает вид, что знает."
    Bitt "（苦涩）但我可以带你去见一个知道的人。或者至少，假装知道的人。"

# game/code/text/text_hells_kenodox.rpy:829
translate chinese kenodox_205c2505:

    # Kav "Что? Кто это? Где он?"
    Kav "（卡维亚尼）什么？是谁？他在哪里？"

# game/code/text/text_hells_kenodox.rpy:831
translate chinese kenodox_2215cc8e:

    # Bitt "Если ты будешь проявлять такое пылкое нетерпение, я могу начать ревновать."
    Bitt "（苦涩）你这么着急，我可能会嫉妒的。"

# game/code/text/text_hells_kenodox.rpy:833
translate chinese kenodox_b207e1f2:

    # Bitt "Кто? Очень, очень старый человек. Где? Глубоко внизу. Где-то в шахтах. Плёнка вечно течёт и изменяется, словно река, поэтому придётся его поискать."
    Bitt "（苦涩）你问是谁？一个非常、非常老的老人。你问在哪里？在很深的地方。矿坑的某处。膜总是在流动和变化，像河流一样，所以我们得去找他。"

# game/code/text/text_hells_kenodox.rpy:834
translate chinese kenodox_24cbbd42:

    # This "Старый человек… Надеюсь, что это правда. Чтобы хоть что-то знать о первопричинах происходящего, нужно быть действительно старым."
    This "一个老人……希望这是真的。要了解正在发生之事的根源，你必须真的非常老才行。"

# game/code/text/text_hells_kenodox.rpy:840
translate chinese kenodox_c764f7b1:

    # This "Горечь была права. Тут воняет."
    This "苦涩说得对。这里臭气熏天。"

# game/code/text/text_hells_kenodox.rpy:841
translate chinese kenodox_85e31ef8:

    # This "Душно. Воздух плотный как суп, который приходится есть носом. Ещё немного, и из ноздрей потечёт сконденсировавшаяся слизь."
    This "很闷。空气浓稠得像汤，你得用鼻子去“吃”。再多待一会儿，我的鼻孔就要流出冷凝的黏液了。"

# game/code/text/text_hells_kenodox.rpy:842
translate chinese kenodox_d963555f:

    # This "По тесным коридорам проносятся волны жаркого ветра. Вместе с ним доносятся звуки: крики, шорох и треск, несмолкаемый стук сотен костяных мотыг о камень и плоть."
    This "热浪扫过狭窄的走廊。随之而来的是各种声音：尖叫、窸窣声和噼啪声，以及数百把骨锄无休止地敲击石头和血肉的咔嗒声。"

# game/code/text/text_hells_kenodox.rpy:843
translate chinese kenodox_0f56a2f5:

    # This "По телу пробегает судорога тошноты. Моя рука сама собой поднимается в воздух и машет остриём. Раз-два."
    This "一阵恶心的痉挛传遍我的身体。我的手不由自主地举到空中，用指尖比划着。一下，两下。"

# game/code/text/text_hells_kenodox.rpy:844
translate chinese kenodox_9770a0b9:

    # This "Простое и понятное существование. Чем оно хуже жизни в Городе?"
    This "一种简单而清晰的存在。这比生活在城市里差在哪里呢？"

# game/code/text/text_hells_kenodox.rpy:845
translate chinese kenodox_08596730:

    # This "Но я не могу остаться здесь. Даже тот глупый демон, голова которого растворилась в едком бассейне, оказался прав — вечный пожар плавит мой разум, не давая остановиться."
    This "但我不能留在这里。就连那个蠢恶魔——它的头颅已在刺鼻的池中溶解——也是对的：永恒之火正在熔化我的理智，让我无法停下。"

# game/code/text/text_hells_kenodox.rpy:846
translate chinese kenodox_bc132d28:

    # This "Злость, обида, жажда мести… А теперь ещё и любопытство."
    This "愤怒、怨恨、复仇的渴望……现在，又加上了好奇。"

# game/code/text/text_hells_kenodox.rpy:848
translate chinese kenodox_282df5e6:

    # This "Медленно копошащаяся груда обнажённых тел — искажённых, переломанных и сросшихся обратно. Стоны и хрипы полубезумных людей."
    This "一堆赤裸的身体缓慢地蠕动着——它们被撕裂、折断，又重新融合在一起。半疯的人们发出呻吟和喘息。"

# game/code/text/text_hells_kenodox.rpy:849
translate chinese kenodox_ed197e0e:

    # This "Мой дом. Моя семья. Здесь я провёл столько времени, что почти забыл, как говорить."
    This "我的家。我的家人。我在这里度过了如此漫长的时间，几乎忘记了如何说话。"

# game/code/text/text_hells_kenodox.rpy:850
translate chinese kenodox_13011203:

    # This "Лишение памяти и разрушение моего разума было не наказанием, а милосердием. Необходимой мерой, чтобы я смог выдержать всё это."
    This "记忆的抹除与心智的摧毁并非惩罚，而是一种仁慈。是我能承受这一切的必要措施。"

# game/code/text/text_hells_kenodox.rpy:851
translate chinese kenodox_04ee11c9:

    # This "Не стоило сюда возвращаться. Пока я ещё могу удержать за закрытой дверью воспоминания о том, что я ел. Где я спал."
    This "我不该回到这里。当我还能紧闭房门时，尚能压抑关于我吃了什么、睡在哪里的记忆。"

# game/code/text/text_hells_kenodox.rpy:855
translate chinese kenodox_bf41caf7:

    # Bitt "Ты не рад? Мы пришли повидать твоих друзей."
    Bitt "你不高兴吗？我们来看你的朋友们了。"

# game/code/text/text_hells_kenodox.rpy:856
translate chinese kenodox_3289b785:

    # Bitt "Можешь ударить кого-нибудь из них, если хочешь. Станет легче."
    Bitt "如果你想的话，可以打他们其中一个。这会让你好受些。"

# game/code/text/text_hells_kenodox.rpy:858
translate chinese kenodox_6ee845b1:

    # This "Я передёрнулся. Насколько же естественным и привлекательным звучит её предложение. Как же легко и приятно его принять."
    This "我抽搐了一下。她的提议听起来多么自然又诱人。接受它是如此轻松愉快。"

# game/code/text/text_hells_kenodox.rpy:859
translate chinese kenodox_9aee8406:

    # This "Как сильно я изменился? Джосайя вернул себе память, это верно. Но у меня есть и своя память, свои переживания и мечты."
    This "我改变了多少？约西亚找回了记忆，这没错。但我也有自己的记忆、自己的经历和梦想。"

# game/code/text/text_hells_kenodox.rpy:860
translate chinese kenodox_73c51df0:

    # This "Я — больше, чем Джосайя. А он — всего лишь часть меня. Какая-то часть меня принадлежит этому месту так же, как Джосайя принадлежит Городу."
    This "我不只是约西亚。而他只是我的一部分。我的某部分属于这个地方，就像约西亚属于城市一样。"

# game/code/text/text_hells_kenodox.rpy:861
translate chinese kenodox_168f53d3:

    # This "Примирить две эти части будет нелегко."
    This "调和这两部分不会是个轻松的任务。"

# game/code/text/text_hells_kenodox.rpy:873
translate chinese kenodox_cefdf8f9:

    # OldMiner "Тут я! Тут… Работал! Госпожа… и господин."
    OldMiner "我在这儿！在这儿……我在这里工作过！女主人……还有男主人。"

# game/code/text/text_hells_kenodox.rpy:877
translate chinese kenodox_853daab4:

    # This "Я стал господином? Только из-за того, что моя кожа покраснела после жгучей ванны? Или кто-то видел мою стычку с демоном?"
    This "我成了男主人吗？仅仅因为我在灼热的浴池中皮肤变红了？还是有人看到了我与恶魔的冲突？"

# game/code/text/text_hells_kenodox.rpy:878
translate chinese kenodox_6b16b023:

    # This "Скорее всего, ответ гораздо проще. Я больше не боюсь Горечи; не сгибаюсь перед ней в поклоне и не отвожу взгляд."
    This "最可能的答案是简单得多：我不再害怕苦涩；我不在她面前鞠躬，也不移开视线。"

# game/code/text/text_hells_kenodox.rpy:879
translate chinese kenodox_b7fd414c:

    # This "В Городе одной только смелости недостаточно. Наоборот, смелость приведёт тебя в Храм Нежной Смерти только быстрее."
    This "在城市里，仅有勇气是不够的。相反，勇气只会让你更快地进入温柔死亡神殿。"

# game/code/text/text_hells_kenodox.rpy:883
translate chinese kenodox_c801fc44:

    # OldMiner "Что-то нужно? Что-то нужно? У нас осталось немного овощей… "
    OldMiner "您需要什么吗？需要任何东西吗？我们还剩下一些蔬菜……"

# game/code/text/text_hells_kenodox.rpy:890
translate chinese kenodox_80754534:

    # Bitt "Не суетись. Лучше скажи, где Кирпич."
    Bitt "别大惊小怪。你最好告诉我砖头在哪儿。"

# game/code/text/text_hells_kenodox.rpy:897
translate chinese kenodox_7d81c186:

    # OldMiner "Кирпич? Это… Недалеко. Висит. Молчит. Уплыл ближе к конюшне, за машинкой."
    OldMiner "砖头？它……它不远。它挂着。它很安静。在马厩附近，机器后面。"

# game/code/text/text_hells_kenodox.rpy:904
translate chinese kenodox_37c28e1d:

    # Bitt "Отлично. Я зайду позже, чтобы лично отблагодарить тебя."
    Bitt "很好。我待会儿回来亲自感谢你。"

# game/code/text/text_hells_kenodox.rpy:905
translate chinese kenodox_e2132413:

    # This "Старший Смены затрясся так сильно, что отправил волны вибрации по пластам мяса под ногами."
    This "工头剧烈地颤抖着，以至于他脚下层层叠叠的肉都荡起了涟漪。"

# game/code/text/text_hells_kenodox.rpy:911
translate chinese kenodox_391b8ca2:

    # This "Бедняга. Хотелось его утешить; но что я могу? Впрочем, его утешат эндорфины, которые он получит после первого же удара. Справедливо и честно."
    This "可怜的家伙。我想安慰他，但我能做什么呢？不过，第一击之后分泌的内啡肽会安慰他的。公平合理。"

# game/code/text/text_hells_kenodox.rpy:915
translate chinese kenodox_2df5060b:

    # This "Сеть пещер пронизывает скалу, словно кровеносные сосуды. Малое повторяется в большом. Паутина багровых и синих жилок на стенах как будто рисует карту шахт."
    This "洞穴网络像血管一样穿透岩石。小的在大的内部重复。墙上猩红与蓝色的脉络网，仿佛在绘制矿井的地图。"

# game/code/text/text_hells_kenodox.rpy:916
translate chinese kenodox_a7952708:

    # This "Может быть, если прижаться к стене, она нашепчет тебе, где именно ты находишься в этой сетке. Невозможно заблудиться, если ты готов слушать этот голос."
    This "也许，如果我紧贴墙壁，它会低语告诉我此刻在这张网中的确切位置。只要你愿意倾听那个声音，就不可能迷路。"

# game/code/text/text_hells_kenodox.rpy:917
translate chinese kenodox_dd2740a9:

    # This "Я не готов. Лучше отрезать себе уши."
    This "我还没准备好。我宁愿割掉自己的耳朵。"

# game/code/text/text_hells_kenodox.rpy:919
translate chinese kenodox_5f5addef:

    # This "Где-то здесь я увидел говорящую лошадь. Нет. Человека, превращённого в лошадь."
    This "在这附近某处，我曾见过一匹会说话的马。不。一个变成马的人。"

# game/code/text/text_hells_kenodox.rpy:920
translate chinese kenodox_c6faa100:

    # This "В душе собрался холодный комок настоящего, искреннего страха. Как хорошо, что со мной Горечь."
    This "一团冰冷、真实而纯粹的恐惧在我灵魂中聚集。幸好苦涩和我在一起。"

# game/code/text/text_hells_kenodox.rpy:921
translate chinese kenodox_fcd51bd1:

    # Kav "Франк-спаситель, что я несу…"
    Kav "救世主弗兰克啊，我在说什么呢……"

# game/code/text/text_hells_kenodox.rpy:925
translate chinese kenodox_26fb43fa:

    # Bitt "Что ты несёшь?"
    Bitt "你在说什么？"

# game/code/text/text_hells_kenodox.rpy:927
translate chinese kenodox_a858e661:

    # Kav "Ничего."
    Kav "没什么。"

# game/code/text/text_hells_kenodox.rpy:928
translate chinese kenodox_a74b2318:

    # Kav "На секунду я порадовался, что ты со мной."
    Kav "有那么一瞬间，我很高兴你和我在一起。"

# game/code/text/text_hells_kenodox.rpy:930
translate chinese kenodox_8262e75e:

    # Bitt "Я могу быть всегда с тобой. Хочешь, прирастим тебе пару моих пальцев? Ты можешь гладить ими себя и думать, что это делаю я."
    Bitt "我可以永远陪着你。你想要移植我的一对手指吗？有了它们，你就能抚摸自己，并想象是我在这么做。"

# game/code/text/text_hells_kenodox.rpy:932
translate chinese kenodox_07492a3f:

    # This "Так вот что она думает, когда касается своего тела ужасающей гребёнкой фаланг… Сколько людей касается её в этот момент?"
    This "原来她就是用那可怕的指骨山脊触碰自己身体时这么想的……此刻有多少人在触碰她？"

# game/code/text/text_hells_kenodox.rpy:934
translate chinese kenodox_e96ddffb:

    # Bitt "Но только пару. Остальное моё."
    Bitt "但只有一对是别人的。其余都是我的。"

# game/code/text/text_hells_kenodox.rpy:936
translate chinese kenodox_fa13c92e:

    # Kav "Я… я подумаю."
    Kav "我……我会考虑的。"

# game/code/text/text_hells_kenodox.rpy:937
translate chinese kenodox_4f651124:

    # This "В конце концов, почему бы и нет."
    This "毕竟，为什么不呢？"

# game/code/text/text_hells_kenodox.rpy:938
translate chinese kenodox_21670b8f:

    # This "Горечь задумчиво провела рукой по стене, оставляя на плоти быстро наливающийся кровью след."
    This "苦涩若有所思地用手划过墙壁，留下一道血迹，迅速渗入血肉之中。"

# game/code/text/text_hells_kenodox.rpy:940
translate chinese kenodox_7275e08e:

    # Bitt "Где-то здесь. Иди вперёд и внимательно смотри по сторонам. Как увидишь лицо — заговори с ним."
    Bitt "就在这附近。往前走，仔细看看周围。当你看到一张脸时，就和它说话。"

# game/code/text/text_hells_kenodox.rpy:942
translate chinese kenodox_89828b28:

    # Bitt "Я не пойду. Он меня не любит. Слишком любит другую."
    Bitt "我不去。他不爱我。他太爱别人了。"

# game/code/text/text_hells_kenodox.rpy:944
translate chinese kenodox_18d4b511:

    # Kav "Лицо?"
    Kav "脸？"

# game/code/text/text_hells_kenodox.rpy:946
translate chinese kenodox_1253f7c3:

    # Bitt "Да, лицо. Два глаза, под ними нос, рот… Лицо. Ты знаешь, что это."
    Bitt "对，一张脸。两只眼睛，下面一个鼻子，一张嘴……一张脸。你知道脸是什么。"

# game/code/text/text_hells_kenodox.rpy:947
translate chinese kenodox_b819af22:

    # Kav "Одно только лицо?"
    Kav "就一张脸？"

# game/code/text/text_hells_kenodox.rpy:949
translate chinese kenodox_3c2abf6e:

    # Bitt "Ты поймёшь. Иди, пока я не сломала тебе ноги."
    Bitt "你自己会看到的。在我打断你的腿之前快走。"

# game/code/text/text_hells_kenodox.rpy:951
translate chinese kenodox_8a579cde:

    # This "Она выдала крепкий толчок мне в спину. Я пошатнулся и заковылял вперёд, крутя головой по сторонам."
    This "她在我背上用力推了一把。我倒抽一口气，踉跄着向前走去，环顾四周。"

# game/code/text/text_hells_kenodox.rpy:952
translate chinese kenodox_0d01562b:

    # This "Лицо… На стенах хватало и глаз, и ртов. Мешанина органов и тканей складывалась в самые причудливые узоры."
    This "一张脸……墙上的眼睛和嘴巴够多了。器官和组织以最怪诞的图案混杂在一起。"

# game/code/text/text_hells_kenodox.rpy:953
translate chinese kenodox_2b63637c:

    # This "Сотни зрачков шевелились, реагируя на мою тень. Разноцветье радужек, как россыпь бусин в детской игре."
    This "数百个瞳孔移动着，对我的影子做出反应。彩色的虹膜，像儿童游戏中散落的珠子。"

# game/code/text/text_hells_kenodox.rpy:954
translate chinese kenodox_f990c5d7:

    # This "Наполненные зубами отверстия исторгали нитки слюны, сипели, пытаясь выдавить членораздельное слово. Некоторые из них жадно клацали челюстями — но не в попытках укусить, а только потому, что к ним подведены тяжи мышц."
    This "那些长满牙齿的孔洞，喷出唾液丝线，呜咽着试图挤出清晰的字词。有些贪婪地咔嗒着下巴——并非想咬人，只因为下面连着几束肌肉。"

# game/code/text/text_hells_kenodox.rpy:955
translate chinese kenodox_51191116:

    # This "Местами пара расфокусированных, смотрящих в разные стороны глаз могла случайно оказаться рядом со ртом, раззявленном в беззвучном крике. Но назвать это лицом трудновато."
    This "在某些地方，一对失焦的、看向不同方向的眼睛，可能碰巧挨着一张无声尖叫的嘴。但这很难称之为一张脸。"

# game/code/text/text_hells_kenodox.rpy:960
translate chinese kenodox_d315d57a:

    # This "Внезапно подвижные розовые выросты на стене сложились в грубое и безобразное подобие головы."
    This "突然，墙上可移动的粉色突起物折叠成一个粗糙丑陋、类似头颅的形状。"

# game/code/text/text_hells_kenodox.rpy:961
translate chinese kenodox_3723ffa6:

    # This "Глаза, а под ними нос и рот. Сложены в правильном порядке, но выглядят уродливее, чем обычные волны и потёки мяса. Как будто такому проявлению порядка не место среди цветущего хаоса плоти."
    This "眼睛，以及下方的鼻子和嘴巴。按正确的顺序排列，但看起来比通常的肉浪肉河更丑陋。仿佛在这种血肉绽放的混沌中，秩序的展示毫无容身之地。"

# game/code/text/text_hells_kenodox.rpy:962
translate chinese kenodox_20f7dea7:

    # This "Лицо искажено, иссечено морщинами — словно кто-то попытался прожевать этот кусок стены, но наткнулся на клок волос и с отвращением выплюнул."
    This "那张脸扭曲皱缩，好像有人试图咀嚼这块墙壁，却被一团头发绊住，厌恶地吐了出来。"

# game/code/text/text_hells_kenodox.rpy:963
translate chinese kenodox_bacf4373:

    # This "Просто заговорить с ним… Но что сказать?"
    This "只要和他说话……但我该说什么？"

# game/code/text/text_hells_kenodox.rpy:966
translate chinese kenodox_356ce332:

    # Kav "Э-э… Привет?"
    Kav "呃……你好？"

# game/code/text/text_hells_kenodox.rpy:967
translate chinese kenodox_2377178d:

    # This "Его глаза смотрят в одном направлении. Это хороший знак."
    This "他的眼睛看向同一个方向。这是个好迹象。"

# game/code/text/text_hells_kenodox.rpy:971
translate chinese introduce_a931c896:

    # Kav "Э-э… Я Джосайя."
    Kav "呃……我是约西亚。"

# game/code/text/text_hells_kenodox.rpy:972
translate chinese introduce_5a911d56:

    # This "По крайней мере, отчасти. Это имя ничем не хуже других."
    This "至少，部分是。这个名字和其他任何名字一样好。"

# game/code/text/text_hells_kenodox.rpy:975
translate chinese introduce_51314db8:

    # MainEngi "Отойдите, пожалуйста. Не заслоняйте её."
    MainEngi "请退后。别挡住她。"

# game/code/text/text_hells_kenodox.rpy:977
translate chinese introduce_52ace0c5:

    # Kav "Её?"
    Kav "她？"

# game/code/text/text_hells_kenodox.rpy:979
translate chinese introduce_f33593cb:

    # MainEngi "Да. Кимвэл. Мою Ким."
    MainEngi "是的。金伯。我的金。"

# game/code/text/text_hells_kenodox.rpy:982
translate chinese introduce_57f0d264:

    # This "Я оглянулся за спину. Насколько хватало взгляда, вокруг шевелилась, стонала и потела слизью бесформенная плоть. Всё, как обычно."
    This "我回头看去。目力所及，只有不成形的血肉在蠕动，呻吟着，渗出黏液。这很平常。"

# game/code/text/text_hells_kenodox.rpy:984
translate chinese introduce_8ff5d996:

    # Kav "Я никого не вижу…"
    Kav "我没看到任何人……"

# game/code/text/text_hells_kenodox.rpy:986
translate chinese introduce_11d18a96:

    # MainEngi "Она немного расплылась с годами. Но всё так же хороша."
    MainEngi "这些年来她变得有点模糊了。但她还是和以前一样好。"

# game/code/text/text_hells_kenodox.rpy:988
translate chinese introduce_235cc4ed:

    # This "Лучше не спорить, если я хочу хоть что-нибудь от него узнать."
    This "如果我想从他那里知道些什么，最好不要争辩。"

# game/code/text/text_hells_kenodox.rpy:989
translate chinese introduce_16c8e825:

    # This "Я сдвинулся чуть в сторону. Голова в стене облегчённо закрыла глаза."
    This "我稍微向旁边挪了一步。墙里的头颅如释重负地闭上了眼睛。"

# game/code/text/text_hells_kenodox.rpy:990
translate chinese introduce_f723bfa8:

    # This "Эй, разве ты не хотел смотреть куда-то?!"
    This "嘿，你不是想在这里找什么吗？！"

# game/code/text/text_hells_kenodox.rpy:991
translate chinese introduce_9b13f892:

    # Kav "Кто такая Ким?"
    Kav "金是谁？"

# game/code/text/text_hells_kenodox.rpy:992
translate chinese introduce_70f2abb5:

    # This "Молчание."
    This "沉默。"

# game/code/text/text_hells_kenodox.rpy:993
translate chinese introduce_e832fcfc:

    # Kav "Мне сказали, что ты знаешь больше других."
    Kav "有人告诉我，你知道的比别人多。"

# game/code/text/text_hells_kenodox.rpy:994
translate chinese introduce_8085897a:

    # Kav "Ну, о том, что тут происходит."
    Kav "嗯，关于这里发生的事。"

# game/code/text/text_hells_kenodox.rpy:995
translate chinese introduce_36756d9b:

    # This "Может ли он говорить вообще? Не почудилось ли мне? В последнее время в моей жизни появилось много голосов, принадлежность которых нелегко определить."
    This "他说话了吗？是我在幻想吗？最近我生活中出现了许多难以辨认的声音。"

# game/code/text/text_hells_kenodox.rpy:996
translate chinese introduce_fe6be199:

    # Kav "Мне очень нужно с тобой поговорить."
    Kav "我真的需要和你谈谈。"

# game/code/text/text_hells_kenodox.rpy:997
translate chinese introduce_264d3eac:

    # This "Неумолчный щебет и гомон жизни вокруг. Но ни одного осмысленного слова в этом шуме."
    This "周围只有无声的啁啾和生命的喧嚣。但在嘈杂声中，没有一个有意义的词。"

# game/code/text/text_hells_kenodox.rpy:998
translate chinese introduce_b30c6007:

    # This "Как он смеет меня игнорировать?! Я столько пережил, прошёл такой путь!.. Я не могу уйти отсюда с пустыми руками."
    This "他怎么敢无视我？！我经历了这么多。我一路来到这里……我不能空手而归。"

# game/code/text/text_hells_kenodox.rpy:1001
translate chinese introduce_e92c30f0:

    # Kav "Пожалуйста… Я задам всего пару вопросов."
    Kav "求你了……我就问几个问题。"

# game/code/text/text_hells_kenodox.rpy:1002
translate chinese introduce_538e3b91:

    # This "Я так долго смотрел на неподвижный нарост на стене, что начал сомневаться, голова ли это. Закрытые глаза превратились в складки рыхлой кожи. Рот — просто ещё одна из дыр в живом покрове."
    This "我盯着墙上那静止的突起看了太久，开始怀疑它到底是不是一个头。闭上的眼睛变成了松弛皮肤的褶皱。嘴巴只是活体组织上的另一个孔洞。"

# game/code/text/text_hells_kenodox.rpy:1003
translate chinese introduce_11765558:

    # This "Ладно. С меня хватит. За моей спиной стоит существо, которое может вырвать мне пару рёбер для собственного развлечения, если вдруг соскучится. Нет времени просто стоять."
    This "好吧。我受够了。我身后站着一个生物，如果她无聊了，可能会为了取乐而扯断我几根肋骨。没时间浪费了。"

# game/code/text/text_hells_kenodox.rpy:1007
translate chinese introduce_cc84c382:

    # This "Похоже, в этом месте работает только один подход. Насилие и боль. Не я установил эти правила, но я уже хорошо с ними знаком."
    This "在这个地方，似乎只有一种方法行得通：暴力和痛苦。规则不是我定的，但我已经非常熟悉它们了。"

# game/code/text/text_hells_kenodox.rpy:1008
translate chinese introduce_9d31c99b:

    # Kav "Я вырежу тебе глаза киркой, чтобы ты больше не мог смотреть на свою Ким."
    Kav "我会用镐挖出你的眼睛，让你再也看不到你的金。"

# game/code/text/text_hells_kenodox.rpy:1010
translate chinese introduce_4bec69e2:

    # MainEngi "Это будет весьма невежливо с вашей стороны, молодой человек."
    MainEngi "那你可就太失礼了，年轻人。"

# game/code/text/text_hells_kenodox.rpy:1012
translate chinese introduce_14c58080:

    # This "Сработало! Пусть делает вид, что ему всё равно. Но он заговорил."
    This "奏效了！让他假装不在乎吧。但他说话了。"

# game/code/text/text_hells_kenodox.rpy:1013
translate chinese introduce_f88ebd19:

    # Kav "Это ты Кирпич? Меня направили к тебе."
    Kav "你是砖头吗？有人让我来找你。"

# game/code/text/text_hells_kenodox.rpy:1015
translate chinese introduce_9e39c28a:

    # Brick "Кирпич… Какое грубое слово."
    Brick "砖头……多么刺耳的词。"

# game/code/text/text_hells_kenodox.rpy:1018
translate chinese introduce_ebd770c0:

    # Brick "Камень. Краеугольный камень в основании Города. Это мне больше подходит."
    Brick "石头。城市基石的奠基石。这更适合我。"

# game/code/text/text_hells_kenodox.rpy:1020
translate chinese introduce_ae51b26e:

    # Kav "Так это ты — корень всего этого зла?! Я вырву тебя из стены и…"
    Kav "所以你就是这一切罪恶的根源？！我要把你从墙上扯下来，然后……"

# game/code/text/text_hells_kenodox.rpy:1022
translate chinese introduce_33b3c2a5:

    # Brick "И что ты сделаешь? Убьёшь меня? Я не могу умереть! Ты не можешь умереть. Никто не может. В этом и проблема."
    Brick "然后呢？杀了我？我死不了！你也死不了。没人能死。这就是问题所在。"

# game/code/text/text_hells_kenodox.rpy:1024
translate chinese introduce_8a1f1869:

    # Kav "Не можешь умереть? Тем лучше. Я могу причинить тебе боль."
    Kav "死不了？那更好。我可以让你的生活痛苦不堪。"

# game/code/text/text_hells_kenodox.rpy:1026
translate chinese introduce_41d84640:

    # Brick "А, ты один из этих… В маниакальной фазе. Оживлённость, речевое и двигательное возбуждение, многословие, и это несмотря на то, что повреждён разум, стёрта память…"
    Brick "哦，你是那种……处于躁狂期的。活力充沛，言语和动作兴奋，喋喋不休，而且，尽管心智受损，记忆被抹除……"

# game/code/text/text_hells_kenodox.rpy:1028
translate chinese introduce_0a620a44:

    # Kav "Не стёрта. Я помню Город. Помню, как тут оказался."
    Kav "没有。我记得城市。我记得我是怎么来到这里的。"

# game/code/text/text_hells_kenodox.rpy:1030
translate chinese introduce_c7875b2d:

    # Brick "Хм. Безрукие техники. Или… Энтропия добралась и до этого куска инфраструктуры, да? Не смогли выжечь тебе всё до конца."
    Brick "嗯。那些没用的技术员。还是说……熵也侵蚀到了这块基础设施，嗯？所以他们没能把你脑子里的东西全烧掉，嗯？"

# game/code/text/text_hells_kenodox.rpy:1033
translate chinese introduce_232842f2:

    # Brick "Да, Городу недолго осталось. Даже Франк не смог победить, уговорить или обмануть время."
    Brick "是的，城市时日无多了。连弗兰克也无法战胜、说服或欺骗时间。"

# game/code/text/text_hells_kenodox.rpy:1036
translate chinese introduce_40a8c7ec:

    # Brick "Но это, конечно, уже не моя проблема."
    Brick "但那，当然，已经不再是我的问题了。"

# game/code/text/text_hells_kenodox.rpy:1038
translate chinese introduce_35798c28:

    # This "Голова снова прикрыла глаза. Я злобно треснул киркой по стене рядом с ней."
    This "那颗头再次闭上了眼睛。我愤怒地用镐头敲了敲他旁边的墙壁。"

# game/code/text/text_hells_kenodox.rpy:1049
translate chinese introduce_3ade563b:

    # Kav "Мы не договорили!"
    Kav "我们还没完！"

# game/code/text/text_hells_kenodox.rpy:1051
translate chinese introduce_c02214eb:

    # Brick "Что, что ты хочешь от меня, демон? Чего может хотеть такое существо, как ты? Или тебе недостаточно тех тысяч жертв, что заперты в шахтах биоремедиации?"
    Brick "什么，你想从我这里得到什么，恶魔？像你这样的生物还能想要什么？难道困在生物修复矿坑里的成千上万受害者还不够你享用吗？"

# game/code/text/text_hells_kenodox.rpy:1053
translate chinese introduce_61c9176c:

    # Kav "Я… Я не демон. Мне нужны ответы."
    Kav "我……我不是恶魔。我想要答案。"

# game/code/text/text_hells_kenodox.rpy:1055
translate chinese introduce_5420312f:

    # Brick "Чтобы получить ответ, нужно сначала задать вопрос."
    Brick "要得到答案，你得先提出问题。"

# game/code/text/text_hells_kenodox.rpy:1057
translate chinese introduce_85a63102:

    # This "Да он издевается надо мной."
    This "他在取笑我。"

# game/code/text/text_hells_kenodox.rpy:1058
translate chinese introduce_81dbe9bd:

    # This "Возможно, он будет разговаривать вежливее, если вырезать его из стены и окунуть в бассейн Горечи, предварительно оторвав веки…"
    This "也许如果我把他的眼皮先撕掉，把他从墙上挖出来，浸在苦涩的池子里，他会说得更客气些……"

# game/code/text/text_hells_kenodox.rpy:1059
translate chinese introduce_6ce18a3f:

    # This "Нет. Нет. Я не демон. Пока ещё нет."
    This "不。不。我不是恶魔。还不是。"

# game/code/text/text_hells_kenodox.rpy:1060
translate chinese introduce_ad31e29b:

    # Kav "Почему ты создал эту ужасную систему? Неужели нельзя было придумать что-то другое?"
    Kav "你为什么要创造这个恐怖的系统？你就不能想出点别的吗？"

# game/code/text/text_hells_kenodox.rpy:1061
translate chinese introduce_e173f2bb:

    # This "Голова снова погрузилась в молчание; но в этой тишине слышалось напряжение. На этот раз я решил терпеливо дождаться ответа."
    This "那颗头再次陷入沉默，但在那沉默中，我能听到紧张感。这次，我决定耐心等待答案。"

# game/code/text/text_hells_kenodox.rpy:1063
translate chinese introduce_6296279b:

    # Brick "Этот вопрос я задавал себе снова и снова. Когда лежал в своей кровати там, наверху. Когда висел и медленно сходил с ума тут, внизу. Год за годом."
    Brick "这个问题我问了自己一遍又一遍。当我躺在上面我的床上时。当我在这里徘徊并慢慢发疯时。年复一年。"

# game/code/text/text_hells_kenodox.rpy:1066
translate chinese introduce_3b0b9456:

    # Brick "Почему, Петер, почему? Почему ты не занялся музыкой, как этого хотела мама? Почему не выбрал другую тему для научной работы? Почему не саботировал исследования, когда ещё была такая возможность?"
    Brick "为什么，彼得，为什么？你为什么不按你母亲希望的那样去搞音乐？你为什么不选另一个研究课题？你当初有机会时为什么不破坏这项研究？"

# game/code/text/text_hells_kenodox.rpy:1069
translate chinese introduce_da7f8904:

    # Brick "Амбиции. Демон Амбиции пострашнее тебя, Джосайя. Гранты, премии, слава. И благо человечества, конечно же. Благие намерения, аха-ха-хах."
    Brick "野心。野心恶魔比你更可怕，约西亚。资助，奖项，名誉。当然还有人类的福祉。善意，啊哈哈哈。"

# game/code/text/text_hells_kenodox.rpy:1071
translate chinese introduce_f8f6d103:

    # This "Он бормочет и бормочет непонятные слова себе под нос. Если я буду прерывать его и просить объяснений на каждую фразу, мы останемся здесь навсегда."
    This "他喃喃自语，说着些难以理解的话。如果我打断他，要求解释每一句话，我们会永远待在这里。"

# game/code/text/text_hells_kenodox.rpy:1072
translate chinese introduce_8636437b:

    # This "Нужно задавать краткие, ясные и практичные вопросы. Никаких рассуждений и болтовни."
    This "我需要问简短、清晰、实际的问题。不要推测或修辞。"

# game/code/text/text_hells_kenodox.rpy:1073
translate chinese introduce_288a1c45:

    # Kav "Как всё это остановить?"
    Kav "我怎样才能阻止这一切？"

# game/code/text/text_hells_kenodox.rpy:1075
translate chinese introduce_febf66db:

    # Brick "А ты умеешь выбирать сложные темы, да? Не размениваешься по мелочам."
    Brick "你很会挑复杂的话题，不是吗？你不为小事费心。"

# game/code/text/text_hells_kenodox.rpy:1078
translate chinese introduce_9b8ca816:

    # Brick "Как же долго я бился над этой проблемой. Убить бессмертное. Частичное решение, конечно, нашлось. Но слишком поздно, слишком… К тому же, от жизни нелегко отказаться, знаешь ли. Люди этого не любят."
    Brick "我为这个问题挣扎了多久。杀死一个不朽者。当然，找到了一个部分的解决方案。但太晚了，太……而且，放弃生命并不容易，你知道的。人们不喜欢这样。"

# game/code/text/text_hells_kenodox.rpy:1081
translate chinese introduce_790494a2:

    # Brick "Я предложил им, и посмотри, куда меня это привело."
    Brick "我向他们提供了这个方案，看看我落得什么下场。"

# game/code/text/text_hells_kenodox.rpy:1083
translate chinese introduce_5d8d5fb8:

    # Kav "Какое решение? Где оно?"
    Kav "解决方案是什么？在哪里？"

# game/code/text/text_hells_kenodox.rpy:1085
translate chinese introduce_7f541f1f:

    # Brick "Пф-ф, забудь. Ты едва понимаешь, что я говорю. Куда уж тебе разобраться с настоящей научной проблемой."
    Brick "噗，算了吧。你几乎听不懂我在说什么。你根本不知道如何处理一个真正的科学问题。"

# game/code/text/text_hells_kenodox.rpy:1088
translate chinese introduce_105d8f29:

    # Brick "К тому же, ты плохо слышал, что я сказал? Решение проблемы — это смерть. Смерть для всех и каждого. Или все живут вечно, или все умирают. Паллиатива тут нет."
    Brick "再说了，你没听到我说的话吗？问题的解决方案是死亡。一人与所有人的死亡。要么所有人永生，要么所有人死去。这里没有缓和的办法。"

# game/code/text/text_hells_kenodox.rpy:1091
translate chinese introduce_b9e9c0c4:

    # Brick "Слишком много ошибок я совершил, чтобы брать ещё и этот грех на свою душу."
    Brick "我犯的错误太多了，不能再把这个罪孽也担在我的灵魂上。"

# game/code/text/text_hells_kenodox.rpy:1093
translate chinese introduce_4b140381:

    # This "Упрямый обрубок! Как же просто заставить его. Как же просто начать резать его лицо."
    This "顽固的树桩！让他就范是多么容易。开始切割他的脸是多么容易。"

# game/code/text/text_hells_kenodox.rpy:1094
translate chinese introduce_0eaf0426:

    # This "Я сжал руку в кулак, стараясь дышать через нос."
    This "我握紧拳头，试图用鼻子呼吸。"

# game/code/text/text_hells_kenodox.rpy:1096
translate chinese introduce_5a778928:

    # Brick "Выглядишь взволнованным. Неужели эта тема так для тебя важна? Очень необычно для такого, как ты."
    Brick "你看起来很困扰。这个话题对你如此重要吗？对你这样的人来说很不寻常。"

# game/code/text/text_hells_kenodox.rpy:1099
translate chinese introduce_a4034e58:

    # Brick "Чего ты хочешь?"
    Brick "你想要什么？"

# game/code/text/text_hells_kenodox.rpy:1101
translate chinese introduce_b4ce8575:

    # Kav "Я хочу…"
    Kav "我想要……"

# game/code/text/text_hells_kenodox.rpy:1102
translate chinese introduce_ee56b18e:

    # This "Чего я хочу?"
    This "我想要什么？"

# game/code/text/text_hells_kenodox.rpy:1103
translate chinese introduce_2b28ab4e:

    # This "Я не могу убить того, кто создал этот чудовищный мир."
    This "我无法杀死创造了这个畸形世界的人。"

# game/code/text/text_hells_kenodox.rpy:1104
translate chinese introduce_f9388dc6:

    # This "Я не могу остановить ужасный цикл страданий."
    This "我无法停止这可怕的痛苦循环。"

# game/code/text/text_hells_kenodox.rpy:1105
translate chinese introduce_0cd16a3a:

    # This "Так чего же я хочу теперь?"
    This "那么我现在想要什么？"

# game/code/text/text_hells_kenodox.rpy:1106
translate chinese introduce_4f6cdfd0:

    # This "Из самых глубин души Джосайя прошептал мне ответ."
    This "从我的灵魂深处，约西亚对我低语了一个答案。"

# game/code/text/text_hells_kenodox.rpy:1107
translate chinese introduce_8d4c7464:

    # Kav "Я хочу выйти наружу. Наверх."
    Kav "我想出去。到上面去。"

# game/code/text/text_hells_kenodox.rpy:1108
translate chinese introduce_d8c68656:

    # This "На вросшем в стену лице внезапно проскользнула кривая, едва заметная улыбка."
    This "突然，一丝扭曲的、几乎难以察觉的微笑滑过他嵌在墙里的脸。"

# game/code/text/text_hells_kenodox.rpy:1110
translate chinese introduce_5544c796:

    # Brick "Конечно. Конечно, ты хочешь."
    Brick "你当然想。你当然想。"

# game/code/text/text_hells_kenodox.rpy:1113
translate chinese introduce_3706383d:

    # Brick "К сожалению, наружу тебе нельзя. Не хотелось бы распространять нашу проблемку на всё остальное человечество. Да оно тебя и не выпустит."
    Brick "不幸的是，你出不去。我不想把我们的问题扩展到人类的其他部分。反正他们也不会让你出去。"

# game/code/text/text_hells_kenodox.rpy:1116
translate chinese introduce_656b09a9:

    # Brick "Если же очистить тебя от нашей общей проблемы, то ты незамедлительно умрёшь. Без нанохирургов твоё нынешнее тело не выдержит столь обширных и глубоких модификаций."
    Brick "如果你摆脱了我们共同的问题，你会立刻死去。没有纳米外科医生，你现在的身体无法承受如此广泛而深刻的改造。"

# game/code/text/text_hells_kenodox.rpy:1119
translate chinese introduce_346498c4:

    # Brick "Это про «наружу». Что же касается «наверх»… Наверху так называемый Город."
    Brick "我说的就是那个「外面」。至于「上面」……上面有所谓的城市。"

# game/code/text/text_hells_kenodox.rpy:1121
translate chinese introduce_65579bf6:

    # This "Тот самый Город, который обрёк меня на эту судьбу."
    This "正是那个将我判入此等命运的城市。"

# game/code/text/text_hells_kenodox.rpy:1122
translate chinese introduce_a7b11fe6:

    # Kav "Да. Город. Мне нужно туда."
    Kav "是的。城市。我必须去那里。"

# game/code/text/text_hells_kenodox.rpy:1124
translate chinese introduce_d8c003fb:

    # Brick "Боюсь, туда тебе тоже нельзя. По крайней мере, одним куском. Иначе последние остатки комплекса превратятся в такой же анатомический театр, как и окрестности."
    Brick "恐怕你也去不了那里。至少，无法完整地去。否则，这复合体最后的残余部分就会变成解剖剧场，就像周边区域一样。"

# game/code/text/text_hells_kenodox.rpy:1127
translate chinese introduce_0cd4878d:

    # Brick "Если же ты не против разложиться на более примитивные составляющие, то в Город они попадут. Слабое утешение, конечно."
    Brick "如果你不介意分解成更原始的组成部分，它们会进入城市。当然，这没什么好安慰的。"

# game/code/text/text_hells_kenodox.rpy:1129
translate chinese introduce_8cc9ff34:

    # Kav "Но почему нельзя? Что плохого в том, чтобы принести этот ад в Город? Город создал это место, наполнил его, держится на нём и питается им."
    Kav "但我为什么不能？把这场地狱带到城市有什么错？城市创造了这个地方，并填满了它。它维系着这里，并以此为食。"

# game/code/text/text_hells_kenodox.rpy:1130
translate chinese introduce_c6ac53a3:

    # Kav "Город — это мы."
    Kav "城市就是我们。"

# game/code/text/text_hells_kenodox.rpy:1131
translate chinese introduce_b0002e4b:

    # This "Да. Если мы — часть Города, то Город — это мы."
    This "是的。如果我们是城市的一部分，那么城市就是我们。"

# game/code/text/text_hells_kenodox.rpy:1132
translate chinese introduce_a70070df:

    # This "А я, со своей памятью и своими желаниями — такой же Джосайя, как и тот, кто жил в Городе. Тот, кто рубил плоть и камень, задыхаясь от густого смрада шахт, так же важен, как и тот, кто мечтал работать в Министерстве."
    This "而我，带着我的记忆和我的欲望，既是那个生活在城市里的约西亚，也是这个约西亚。那个在矿坑浓重的恶臭中窒息，劈砍血肉和石头的人，和那个梦想在部委工作的人一样重要。"

# game/code/text/text_hells_kenodox.rpy:1134
translate chinese introduce_fc3bb4f3:

    # Brick "Люди в Городе имеют право на свой образ жизни…"
    Brick "城市里的人有权拥有他们的生活方式……"

# game/code/text/text_hells_kenodox.rpy:1136
translate chinese introduce_67ae2417:

    # Kav "Люди в Городе страдают точно так же, как и тут! После чего всё равно оказываются здесь, так или иначе!"
    Kav "城市里的人受苦的程度和这里一样！而且他们最终还是会来到这里！"

# game/code/text/text_hells_kenodox.rpy:1137
translate chinese introduce_e67db20e:

    # Kav "Так какой смысл откладывать неизбежное? Зачем тратить время?"
    Kav "那么推迟不可避免的事情有什么意义？为什么要浪费时间？"

# game/code/text/text_hells_kenodox.rpy:1139
translate chinese introduce_2fb633a9:

    # Brick "Ты предлагаешь мне выбирать судьбу Города? Предлагаешь мне снова брать грех на душу?"
    Brick "你是建议我为城市选择命运吗？你是建议我再次将罪孽担在我的灵魂上吗？"

# game/code/text/text_hells_kenodox.rpy:1141
translate chinese introduce_c3b96d5e:

    # Kav "Я могу выбрать за тебя. Я возьму этот грех."
    Kav "我可以替你选择。我来承担那个罪孽。"

# game/code/text/text_hells_kenodox.rpy:1142
translate chinese introduce_01161079:

    # Kav "У меня отобрали личность и память, взамен дав только боль ран и страх насилия. Но эти страдания только освободили меня от необходимости в отдыхе, сне, еде или комфорте."
    Kav "我的身份和记忆被夺走了，作为交换，我只得到了伤口的痛苦和对暴力的恐惧。但这痛苦只让我摆脱了对休息、睡眠、食物或舒适的需求。"

# game/code/text/text_hells_kenodox.rpy:1143
translate chinese introduce_7a00751c:

    # Kav "Я — своё собственное создание, вылепленное из бесформенности, чтобы вынести ужасы этого мира. Созданное, чтобы быть сильнее и твёрже. Лучше."
    Kav "我是我自己的造物，被塑造成无形之躯以承受这个世界的恐怖。被创造得更强大、更坚定。更好。"

# game/code/text/text_hells_kenodox.rpy:1144
translate chinese introduce_1403e28c:

    # Kav "Может быть, мы не просто часть Города. Может быть, мы — его будущее."
    Kav "也许我们不仅仅是城市的一部分。也许我们是它的未来。"

# game/code/text/text_hells_kenodox.rpy:1145
translate chinese introduce_4955b8fa:

    # This "Я замолк, захлебнувшись собственным гневом. В ушах стучала кровь — от этой же крови жгло глаза."
    This "我停下来，被自己的愤怒呛住。血液在我耳中轰鸣，同样的血液在我眼中燃烧。"

# game/code/text/text_hells_kenodox.rpy:1146
translate chinese introduce_001a011b:

    # This "Некоторое время Кирпич только смотрел на меня, словно его губы наконец срослись между собой."
    This "砖头只是盯着我看了一会儿，仿佛他的嘴唇终于融合在了一起。"

# game/code/text/text_hells_kenodox.rpy:1148
translate chinese introduce_5a49d6eb:

    # Brick "Господи, кто вложил эти слова в твою голову? Не может же такого быть, чтобы ты выдумал это сам. Гуло?.. Он мог бы, но ты не похож на его слугу… Гордецы-инженеры, но им-то зачем…"
    Brick "天啊，是谁把这些话塞进你脑袋里的？你自己不可能编出来。古洛？……他倒是能干得出来，但你不像是他的仆从……骄傲的工程师们？但他们为什么要这么做？……"

# game/code/text/text_hells_kenodox.rpy:1150
translate chinese introduce_e6faceb1:

    # This "Он снова сбился на неразборчивое, не имеющее смысла бормотание."
    This "他又转向了难以理解、毫无意义的喃喃自语。"

# game/code/text/text_hells_kenodox.rpy:1152
translate chinese introduce_9ef10346:

    # Brick "Неважно. Всё это перестало иметь значение много лет назад."
    Brick "不重要了。这一切在多年前就不再重要了。"

# game/code/text/text_hells_kenodox.rpy:1155
translate chinese introduce_7b462001:

    # Brick "Дни Города сочтены. Если тебе не смогли стереть память до конца, значит, неизбежная деградация уже добралась до центральных, самых важных систем."
    Brick "城市的日子屈指可数了。如果他们连你的记忆都无法妥善抹除，那就意味着不可避免的退化已经触及了核心的、最重要的系统。"

# game/code/text/text_hells_kenodox.rpy:1158
translate chinese introduce_691ed284:

    # Brick "Стоит только рухнуть центральному серверу, и комплекс обрушится в варварство. То самое варварство, в котором он жил изначально, только теперь уже явно и открыто."
    Brick "一旦中央服务器崩溃，整个复合体就会陷入野蛮状态。就是它最初赖以生存的那种野蛮，只是现在变得明确而公开。"

# game/code/text/text_hells_kenodox.rpy:1161
translate chinese introduce_b97c6c7f:

    # Brick "Может быть… Может быть, ты и прав. Возможно, как раз ты и имеешь право решать. Если уж никто другой не осмеливается."
    Brick "也许……也许你是对的。也许有权做决定的是你。如果没人敢的话。"

# game/code/text/text_hells_kenodox.rpy:1163
translate chinese introduce_b291a73e:

    # This "Я затаил дыхание и молча уставился на сморщенное лицо, торчащее из стены."
    This "我屏住呼吸，默默地盯着从墙上伸出的那张布满皱纹的脸。"

# game/code/text/text_hells_kenodox.rpy:1165
translate chinese introduce_7eaccc5a:

    # Brick "Дальше по коридору есть лифт. Мой лифт. Я храню его… сам не знаю, для чего. Наверное, ожидаю чуда."
    Brick "沿着走廊再往下走，有一部电梯。我的电梯。我留着它……我不知道为什么。我想我在等待奇迹。"

# game/code/text/text_hells_kenodox.rpy:1168
translate chinese introduce_3a5d246e:

    # Brick "Он заблокирован, но я попрошу Плёнку-Конгломерат запустить его. После чего ты со своими рогатыми друзьями сможешь тайно подняться наверх. А следом за вами потянется и плоть."
    Brick "它被封锁了，但我会让聚合膜启动它。然后你和你的长角朋友们就可以偷偷上楼了。然后血肉会跟上。"

# game/code/text/text_hells_kenodox.rpy:1171
translate chinese introduce_fffa642d:

    # Brick "Учти — Город не сдастся без боя. Впрочем, не мне вас учить насилию."
    Brick "但要小心——城市不会不战而降。不过我不必教你如何使用暴力。"

# game/code/text/text_hells_kenodox.rpy:1173
translate chinese introduce_682be1dc:

    # Kav "Я понял. Спасибо."
    Kav "我明白了。谢谢。"

# game/code/text/text_hells_kenodox.rpy:1175
translate chinese introduce_a996fc8e:

    # Brick "Не утомляй меня ритуалами вежливости, которых ты всё равно не знаешь. Лучше уйди поскорее. Я хочу остаться наедине с Ким."
    Brick "别用你反正也不懂的礼貌仪式来烦我。你最好快点离开。我想和金单独待着。"

# game/code/text/text_hells_kenodox.rpy:1177
translate chinese introduce_8b1f4e83:

    # This "Зачем-то чуть поклонившись, я отступил назад в пещеру. Уже через пару шагов уродливый нарост головы полностью слился с трепещущим плетением мяса."
    This "不知为何，我微微鞠了一躬，退回了洞穴。走了几步后，那颗丑陋的头颅增生完全融入了飘动的血肉编织物中。"

# game/code/text/text_hells_kenodox.rpy:1181
translate chinese introduce_0285af12:

    # This "Это бесконечно старое и бесконечно уставшее существо держало на своих плечах весь груз Города, груз знаний и памяти о принятых решениях."
    This "这个无限古老又无限疲惫的生物，肩上承载着整个城市的重量，知识的重量，以及所做决定的记忆。"

# game/code/text/text_hells_kenodox.rpy:1182
translate chinese introduce_56395711:

    # This "Боль могла бы стать освобождением и для него. Но я не доставлю ему такого удовольствия. Пока ещё нет. Он ещё не искупил своё преступление."
    This "痛苦对他而言或许也是一种解脱。但我不会给他这种愉悦。还不是时候。他尚未赎清自己的罪孽。"

# game/code/text/text_hells_kenodox.rpy:1183
translate chinese introduce_675c13e2:

    # This "Но когда-нибудь, возможно, я сюда вернусь."
    This "但也许有一天，我会回到这里。"

# game/code/text/text_hells_kenodox.rpy:1187
translate chinese introduce_0316231d:

    # Bitt "Он заговорил?"
    Bitt "他说话了？"

# game/code/text/text_hells_kenodox.rpy:1188
translate chinese introduce_9719d5e4:

    # Kav "Да."
    Kav "嗯。"

# game/code/text/text_hells_kenodox.rpy:1190
translate chinese introduce_d8eac06b:

    # Bitt "И рассказал то, что тебе было нужно?"
    Bitt "他告诉了你需要知道的事？"

# game/code/text/text_hells_kenodox.rpy:1192
translate chinese introduce_9719d5e4_1:

    # Kav "Да."
    Kav "嗯。"

# game/code/text/text_hells_kenodox.rpy:1196
translate chinese introduce_278e1b8f:

    # Bitt "Ого. Что ты для этого сделал? Вырвал ему глаз?"
    Bitt "哇哦。你为此做了什么？挖了他的眼睛？"

# game/code/text/text_hells_kenodox.rpy:1198
translate chinese introduce_a2e87294:

    # Kav "Просто вежливо попросил."
    Kav "只是礼貌地请求。"

# game/code/text/text_hells_kenodox.rpy:1200
translate chinese introduce_151c8f73:

    # Bitt "Звучит мучительно. Ты должен научить меня этому."
    Bitt "听起来真扭曲。你得教教我。"

# game/code/text/text_hells_kenodox.rpy:1202
translate chinese introduce_31a2e513:

    # This "После разговора с краеугольным камнем этого мира слова Горечи звучали лёгкой и беззаботной болтовнёй."
    This "与这个世界的基石交谈过后，苦涩的话语听起来就像轻松随意的闲聊。"

# game/code/text/text_hells_kenodox.rpy:1203
translate chinese introduce_aefe6e5e:

    # This "Если она может быть свободной и радостной в таком ужасном месте, значит, я прав. Я должен, обязан быть прав."
    This "如果她能在如此可怕的地方保持自由和快乐，那我的选择就是对的。我必须、必须是正确的。"

# game/code/text/text_hells_kenodox.rpy:1204
translate chinese introduce_a9d94194:

    # This "Иначе Город погибнет напрасно."
    This "否则，城市的覆灭就毫无意义。"

# game/code/text/text_hells_kenodox.rpy:1210
translate chinese introduce_72400c10:

    # This "Боль бурлит в нервах жгучими пузырьками — словно выходят примеси из расплава, которым стало моё тело."
    This "疼痛在我的神经中上下翻涌，如同我这具已化作熔融之躯里的杂质。"

# game/code/text/text_hells_kenodox.rpy:1211
translate chinese introduce_c81ba139:

    # This "Руки и ноги онемели. Если не шевелиться, то можно представить, что тела у меня нет вовсе."
    This "我的四肢麻木了。如果不动，我几乎可以假装自己根本没有身体。"

# game/code/text/text_hells_kenodox.rpy:1215
translate chinese introduce_1c887868:

    # Brigitte2 "Вставай уже, хватит страдать! Ну выгнали тебя из Министерства, так что теперь, не жить?"
    Brigitte2 "起来。够了！他们把你赶出部里又怎样？"

# game/code/text/text_hells_kenodox.rpy:1217
translate chinese introduce_d8f4003f:

    # Kav "Ты кто?"
    Kav "你是谁？"

# game/code/text/text_hells_kenodox.rpy:1219
translate chinese introduce_b2ba41a2:

    # Brigitte2 "Кланк в пальто! Если не встанешь, я заверну тебя в одеяло и вынесу на руках."
    Brigitte2 "鞋中之铁！你再不起来，我就用毯子裹住你，把你抱出去。"

# game/code/text/text_hells_kenodox.rpy:1221
translate chinese introduce_4043e7c4:

    # Kav "Я не хочу."
    Kav "我不想。"

# game/code/text/text_hells_kenodox.rpy:1223
translate chinese introduce_1ff6d895:

    # Brigitte3 "Я знаю, что не хочешь. Именно поэтому я тут. Чтобы заставлять мелкого Джоза шевелиться, когда он не хочет."
    Brigitte3 "我知道你不想。所以我来了。就是为了在小约兹不想动的时候让他动起来。"

# game/code/text/text_hells_kenodox.rpy:1225
translate chinese introduce_f07ab726:

    # Brigitte3 "Пойдём, завоюем этот Город вместе! Пусть даже тебе придётся сначала поработать младшим менеджером по чистоте нижних этажей."
    Brigitte3 "让我们一起去征服这座城市！哪怕你得先从底层清洁副经理干起。"

# game/code/text/text_hells_kenodox.rpy:1227
translate chinese introduce_6411341f:

    # Kav "Но я не хочу…"
    Kav "但我不想……"

# game/code/text/text_hells_kenodox.rpy:1231
translate chinese introduce_433fe672:

    # Brigitte3 "Тогда ты мне не нужен. И никогда не был нужен."
    Brigitte3 "那我就不需要你了。我也从来不需要你。"

# game/code/text/text_hells_kenodox.rpy:1236
translate chinese introduce_962b3443:

    # Brigitte3 "Инертный, трусливый и слабый. Мне приходилось быть сильной ради тебя. Из-за тебя."
    Brigitte3 "你迟钝、懦弱、软弱。我不得不为你变得坚强。都是因为你。"

# game/code/text/text_hells_kenodox.rpy:1237
translate chinese introduce_b1e5405b:

    # Brigitte3 "Город не прощает сильных. Поэтому я здесь."
    Brigitte3 "城市不会原谅强者。所以我才会在这里。"

# game/code/text/text_hells_kenodox.rpy:1239
translate chinese introduce_faf65809:

    # Kav "Я не виноват!.."
    Kav "这不是我的错！……"

# game/code/text/text_hells_kenodox.rpy:1241
translate chinese introduce_12cba824:

    # Brigitte3 "Конечно. Маленький Джоз старается ничего не делать, чтобы никогда не быть виноватым. Лучше посидеть в шкафу, чем расстроить Старших."
    Brigitte3 "当然。小约兹尽量什么都不做，这样他就永远不会犯错。宁可缩在壁橱里，也别惹长官们不高兴。"

# game/code/text/text_hells_kenodox.rpy:1248
translate chinese introduce_b5add258:

    # This "Расслабься, закрой глаза, отпусти свои мысли — и ты попадёшь в шкаф."
    This "放松，闭上眼睛，放空思绪，你就能抵达那个壁橱。"

# game/code/text/text_hells_kenodox.rpy:1249
translate chinese introduce_fb9d73bc:

    # This "Ты ведь не хочешь никого разочаровывать? Не хочешь быть обузой, проблемой?"
    This "你不想让任何人失望，对吧？你不想成为负担，不想惹人厌烦？"

# game/code/text/text_hells_kenodox.rpy:1252
translate chinese introduce_3cf23250:

    # Kav "Нет!.."
    Kav "不！……"

# game/code/text/text_hells_kenodox.rpy:1258
translate chinese introduce_71f741f3:

    # Bitt "Ты так забавно пытаешься кричать под водой. Продолжай."
    Bitt "你真有趣，居然想在水下尖叫。继续。"

# game/code/text/text_hells_kenodox.rpy:1260
translate chinese introduce_1b10c057:

    # This "Пальцы заныли от шероховатости каменного пола. Почему они так чувствительны? Минуту назад я думал, что у меня нет рук, а теперь они горят огнём."
    This "我的手指被粗糙的石地硌得生疼。它们为何如此敏感？一分钟前我还以为自己没有手，现在它们却像在燃烧。"

# game/code/text/text_hells_kenodox.rpy:1261
translate chinese introduce_c101cbe4:

    # Bitt "Если ты будешь столько времени проводить в бассейне, то окончательно лишишься кожи. Организм привыкнет к её постоянному растворению и начнёт считать это новой нормой."
    Bitt "如果你在池子里待太久，皮肤会永久丧失。身体会习惯持续的溶解，并开始将其视为新的常态。"

# game/code/text/text_hells_kenodox.rpy:1263
translate chinese introduce_4fa2a7bb:

    # Bitt "Интересно, сможешь ли ты необратимо выжечь себе глаза."
    Bitt "我在想，眼睛会不会被不可逆地灼瞎。"

# game/code/text/text_hells_kenodox.rpy:1264
translate chinese introduce_e5f902a2:

    # Kav "Я… я видел сны."
    Kav "我……我做了梦。"

# game/code/text/text_hells_kenodox.rpy:1265
translate chinese introduce_e3101c6a:

    # Bitt "Если долго и упорно вырезать человеку один и тот же глаз, второй глаз начнёт отваливаться сам. Ты знал об этом?"
    Bitt "如果你长时间用力挖掉人的一只眼睛，另一只眼睛会自行脱落。你知道吗？"

# game/code/text/text_hells_kenodox.rpy:1267
translate chinese introduce_aea2dabd:

    # Bitt "Как ты смог уснуть в моём бассейне? Он создан именно для того, чтобы не давать человеку спать."
    Bitt "你怎么可能在我的池子里睡着？它设计出来就是为了让人保持清醒。"

# game/code/text/text_hells_kenodox.rpy:1269
translate chinese introduce_dea38297:

    # Kav "Я видел сны о прошлом. Воспоминания, которые хранятся у меня в голове."
    Kav "我梦见了过去。储存在我脑海里的记忆。"

# game/code/text/text_hells_kenodox.rpy:1271
translate chinese introduce_246c6338:

    # Bitt "Хранятся? Скорее, навалены кучей, как те шахтёры в своей вонючей норе."
    Bitt "储存？更像是胡乱堆砌，就像那些矿工在他们臭气熏天的洞里一样。"

# game/code/text/text_hells_kenodox.rpy:1273
translate chinese introduce_7d91ab00:

    # Bitt "Кучу разметали, разорвали и выбросили. А ты подобрал пару ошмётков, слепил их в один шар и теперь считаешь это памятью. Выбрось их полностью, и тебе сразу станет легче."
    Bitt "那堆东西被捣毁、撕碎、丢弃了。而你捡起几片碎屑，揉成一团，现在却以为那是记忆。把它们全扔掉，你会好受些。"

# game/code/text/text_hells_kenodox.rpy:1275
translate chinese introduce_730bde72:

    # Kav "Нет! Нет. Ещё не время."
    Kav "不！不行。还不是时候。"

# game/code/text/text_hells_kenodox.rpy:1277
translate chinese introduce_59954bb0:

    # Bitt "Для моей игрушки ты на удивление часто мне отказываешь."
    Bitt "对我的玩具来说，你拒绝我的次数倒是多得惊人。"

# game/code/text/text_hells_kenodox.rpy:1279
translate chinese introduce_caa8a5dc:

    # Bitt "Когда-то это было новым и острым ощущением, но теперь приелось. Лучше тебе придумать что-то новенькое, иначе придумаю я."
    Bitt "这曾经是一种新奇刺激的感觉，但现在无聊了。你最好想点新花样，不然我来想。"

# game/code/text/text_hells_kenodox.rpy:1283
translate chinese introduce_97dfc5de:

    # Kav "Сможешь ли ты собрать других демонов? Будут ли они тебя слушаться?"
    Kav "你能召集其他恶魔吗？他们会听你的吗？"

# game/code/text/text_hells_kenodox.rpy:1285
translate chinese introduce_b3bf4905:

    # This "Сотни пальцев на теле Горечи сжались в пароксизме предвкушения. Она напряглась, как натянутая струна, борясь с собственной хваткой."
    This "苦涩身上的数百根手指在期待的痉挛中攥紧。她像一根绷紧的弦，与自身的抓握对抗着。"

# game/code/text/text_hells_kenodox.rpy:1286
translate chinese introduce_f24ba26c:

    # Bitt "Наконец-то!.."
    Bitt "终于……！"

# game/code/text/text_hells_kenodox.rpy:1288
translate chinese introduce_1ef73a1c:

    # Bitt "Слушаться? Не будут. Но, если ты предлагаешь то, что я думаю, они пойдут вместе с нами."
    Bitt "听我的，你说？他们不会。但如果你提出我想的那个建议，他们会跟我们走的。"

# game/code/text/text_hells_kenodox.rpy:1289
translate chinese introduce_d66064ae:

    # Kav "Тогда пакуй свою коллекцию."
    Kav "那就收拾好你的收藏品。"

# game/code/text/text_hells_kenodox.rpy:1291
translate chinese introduce_96efaf6a:

    # This "Это правда. Мою память уже не собрать обратно. Прошлую жизнь не вернуть."
    This "没错。我的记忆无法再拼凑完整。我无法找回过去的生活了。"

# game/code/text/text_hells_kenodox.rpy:1292
translate chinese introduce_9dc95370:

    # This "Но я могу сделать так, чтобы подобное не случилось больше ни с кем и никогда."
    This "但我可以确保这种事永远不会再发生在任何人身上。"

# game/code/text/text_hells_kenodox.rpy:1293
translate chinese introduce_28670c39:

    # This "Город медленно стекает под землю, напитываясь страданиями по пути. Мучительные попытки отсрочить неизбежное. Сколько лет, сколько поколений это ещё будет продолжаться?"
    This "城市在地底缓缓沉降，沿途浸透着苦难。为推迟必然结局而做的痛苦挣扎。这还要持续多少年，多少代人？"

# game/code/text/text_hells_kenodox.rpy:1294
translate chinese introduce_84d4356c:

    # This "Мы все закончим свой путь здесь, внизу. Лучше вскрыть этот нарыв одним ударом. Пусть даже кто-то испытает неудобства в процессе."
    This "我们最终都会来到这里。不如一举切开这个脓疮。即使过程中有人会感到不适。"

# game/code/text/text_hells_kenodox.rpy:1296
translate chinese introduce_23ae221b:

    # This "Всё те же волны и наплывы плоти на стенах — но всё же неуловимо другие. Морщинистый вырост Кирпича сместился в новое место. Но теперь он мне не нужен."
    This "墙壁上依然是同样的血肉波浪与起伏——但现在它们有了微妙的不同。砖头那皱巴巴的增生转移到了别处。但我现在不需要他了。"

# game/code/text/text_hells_kenodox.rpy:1297
translate chinese introduce_28d9ba70:

    # Kav "Где-то здесь, чуть дальше…"
    Kav "就在这附近，再往前一点……"

# game/code/text/text_hells_kenodox.rpy:1311
translate chinese introduce_90d5ba9d:

    # Bitt "Нужно было вырвать Кирпича из стены и взять с собой. Убедиться, что он не врёт."
    Bitt "我本该把砖头从墙上扯下来带走的。好确认他没撒谎。"

# game/code/text/text_hells_kenodox.rpy:1315
translate chinese introduce_df66b0f6:

    # Kav "Стены изменились. Может быть, он и не врал."
    Kav "这里的墙壁看起来不一样。也许他没说谎。"

# game/code/text/text_hells_kenodox.rpy:1319
translate chinese introduce_a0dd2213:

    # Dm "Стены здесь всегда меняются, Глупый. Иначе в чём…"
    Dm "这里的墙壁总是在变化，蠢货。不然还有什么意……"

# game/code/text/text_hells_kenodox.rpy:1324
translate chinese introduce_be4383a1:

    # This "Мясо зияло огромной воронкой, приглашающе подсвечивая гнойничками металлическую дверь."
    This "血肉如巨大的漏斗般张开，诱人地照亮了那扇脓疱状的金属门。"

# game/code/text/text_hells_kenodox.rpy:1325
translate chinese introduce_a66ff303:

    # This "Неприятно ровные линии и гладкие поверхности створок вызывали желание разбить их киркой. Вместо этого я ткнул остриём кирки в красный огонёк кнопки, едва виднеющийся под занавесом плоти."
    This "门扇那令人不适的平直线条和光滑表面让我想用镐子砸碎它们。但我只是用镐尖轻轻戳了戳红色按钮，它几乎被血肉帘幕完全遮盖。"

# game/code/text/text_hells_kenodox.rpy:1328
translate chinese introduce_29f1eef8:

    # Bitt "Надеюсь, ты знаешь, что делаешь."
    Bitt "希望你清楚自己在做什么。"

# game/code/text/text_hells_kenodox.rpy:1329
translate chinese introduce_079695dc:

    # Kav "Отсюда путь только вверх. Если только ты не скрываешь ещё один слой ада, лежащий под нами."
    Kav "从这里上去只有一条路。除非你在我们下面还藏了一层地狱。"

# game/code/text/text_hells_kenodox.rpy:1330
translate chinese introduce_9fb23b9b:

    # Bitt "О-о, это было бы весело. Но нет. Туда шахтёры ещё не прокопались."
    Bitt "啊，那倒会很有趣。但没有。矿工们还没挖到那里。"

# game/code/text/text_hells_kenodox.rpy:1333
translate chinese introduce_b010dc7e:

    # This "Какой холодный и неуютный свет ламп. Словно отрицающий жизнь."
    This "灯光多么冰冷而不适。仿佛在否定生命本身。"

# game/code/text/text_hells_kenodox.rpy:1334
translate chinese introduce_a9cbee09:

    # This "Ну ничего. Теперь жизнь поднимается к свету сама, хочет он того или нет."
    This "没关系。现在生命正自行升向光明，无论它愿不愿意。"

# game/code/text/text_hells_kenodox.rpy:1336
translate chinese introduce_e14cace2:

    # This "Отсюда пещеры казались тёмной беззубой пастью, жадной глоткой, присосавшейся к дверям лифта. Какая несправедливость. Такой внешний вид больше подходит Городу, жадно высасывающему ресурсы из-под земли."
    This "从这里看，洞穴像一张黑暗、无牙的嘴，贪婪的喉咙，吮吸着电梯门。这不公平。这副模样更适合城市，贪婪地吮吸着地底的资源。"

# game/code/text/text_hells_kenodox.rpy:1337
translate chinese introduce_318c7d39:

    # This "Пусть даже эти ресурсы порождены им самим."
    This "即使这些资源是自行生成的。"

# game/code/text/text_hells_kenodox.rpy:1349
translate chinese introduce_8e7b058c:

    # This "Пол задрожал и толкнулся в подошвы. За стеной скрежетнул надтреснутый крик."
    This "地板震颤着抵住我的脚底。墙后传来一阵刺耳、破碎的哭喊。"

# game/code/text/text_hells_kenodox.rpy:1365
translate chinese introduce_2ed7b5fd:

    # Bitt "Вот этот звук мне нравится. Жаль, что Кирпич не рассказал об этой комнате раньше. Если украсить стены, то здесь можно жить."
    Bitt "这声音我喜欢。真希望砖头早点告诉我这个房间。装饰一下墙壁，就能住在这里了。"

# game/code/text/text_hells_kenodox.rpy:1372
translate chinese introduce_61adb290:

    # Dm "Тесновато."
    Dm "有点挤。"

# game/code/text/text_hells_kenodox.rpy:1379
translate chinese introduce_d8897a7c:

    # Bitt "Всегда можно подрезать то, что не вмещается."
    Bitt "把放不下的部分切掉就行。"

# game/code/text/text_hells_kenodox.rpy:1383
translate chinese introduce_884f6d01:

    # Kav "Можешь жить здесь сколько хочешь, когда мы закончим."
    Kav "等我们完事了，你想在这里住多久都行。"

# game/code/text/text_hells_kenodox.rpy:1386
translate chinese introduce_41ec84e4:

    # This "Кровь стучит в ушах; кровь струится по губам, искусанным от нетерпения. Как высоко находится Город? Поездка кажется бесконечной."
    This "血液在我耳中轰鸣。因不耐而咬破的嘴唇流下鲜血。城市究竟有多高？这趟上升似乎永无止境。"

# game/code/text/text_hells_kenodox.rpy:1388
translate chinese introduce_82bf72f6:

    # This "Пол перестал дрожать именно в тот момент, когда я решил, что мы застряли здесь навсегда."
    This "就在我以为我们会永远困在这里时，地板停止了震动。"

# game/code/text/text_hells_kenodox.rpy:1400
translate chinese introduce_48bf9df2:

    # This "Двери со скрипом разошлись, обнажив кромешный мрак."
    This "门吱呀一声打开，露出深不见底的黑暗。"

# game/code/text/text_hells_kenodox.rpy:1401
translate chinese introduce_b76b49f0:

    # This "Тьма. А за ней — оглушающая тишина. Нет щебетания плоти, нет движения жаркого воздуха."
    This "黑暗。随之而来的是震耳欲聋的寂静。没有血肉的鸣叫，没有热空气的流动。"

# game/code/text/text_hells_kenodox.rpy:1402
translate chinese introduce_764b909f:

    # This "Когда я последний раз видел настоящую темноту?"
    This "我上一次见到真正的黑暗是什么时候？"

# game/code/text/text_hells_kenodox.rpy:1406
translate chinese introduce_f723de8e:

    # Dm "Страшно. Ты идёшь первый."
    Dm "好可怕。你先走。"

# game/code/text/text_hells_kenodox.rpy:1411
translate chinese introduce_63b2c0ad:

    # This "Мёртвое помещение. Пустое и неподвижное. Словно тут никогда и не было ничего живого."
    This "一个死寂的房间。空荡而静止。仿佛从未有任何活物踏足此地。"

# game/code/text/text_hells_kenodox.rpy:1412
translate chinese introduce_b521c38e:

    # This "Неужели я жил здесь когда-то?"
    This "我真的曾在这里生活过吗？"

# game/code/text/text_hells_kenodox.rpy:1413
translate chinese introduce_382cc00a:

    # This "Выход удалось найти не сразу; ещё труднее оказалось открыть его одной рукой."
    This "我花了一些时间才找到出口；用一只手打开它更加困难。"

# game/code/text/text_hells_kenodox.rpy:1417
translate chinese introduce_c02ed1a0:

    # This "Вот он, Город. Полон прямых углов и твёрдых стен. Холодный и сухой воздух дерёт горло, оставляя плёнку на губах."
    This "这就是了，城市。充满了直角与坚硬的墙壁。冰冷干燥的空气撕扯着我的喉咙，在嘴唇上留下一层薄膜。"

# game/code/text/text_hells_kenodox.rpy:1418
translate chinese introduce_8970292f:

    # This "Может быть, ещё не поздно вернуться к прежней жизни. Найти свою комнату, надеть костюм из ткани…"
    This "也许现在回到过去的生活还不算太晚。找到我的房间，穿上西装……"

# game/code/text/text_hells_kenodox.rpy:1426
translate chinese introduce_e62c5992:

    # Bitt "Только посмотри на это место."
    Bitt "看看这地方。"

# game/code/text/text_hells_kenodox.rpy:1427
translate chinese introduce_4ad0fdb1:

    # Bitt "Они всё продумали. Наши тела — лучшая из возможных тюрем. Как мы можем вернуться сюда мирно, если сам этот мир отрицает нас? Для них мы — монстры."
    Bitt "他们考虑到了所有事。我们的身体就是最完美的牢笼。如果这个世界本身都拒绝我们，我们又怎能安然归来？在他们眼中，我们就是怪物。"

# game/code/text/text_hells_kenodox.rpy:1431
translate chinese introduce_8034ba26:

    # Kav "И они правы. Но теперь это уже не имеет значения."
    Kav "他们是对的。但现在这已经不重要了。"

# game/code/text/text_hells_kenodox.rpy:1433
translate chinese introduce_60beb64d:

    # This "Едва слышен шёпот плоти, закованной в пластик и бетон, запертой в клетки и гробы зданий."
    This "你几乎听不见被封在塑料和混凝土里、锁在建筑牢笼与棺椁中的血肉的低语。"

# game/code/text/text_hells_kenodox.rpy:1434
translate chinese introduce_50a57b0d:

    # This "Потерпи. Осталось недолго."
    This "再坚持一下。不会太久了。"

# game/code/text/text_hells_kenodox.rpy:1437
translate chinese introduce_68cb9149:

    # Police "Эй! Вы кто? Что с вами?"
    Police "嘿！你是谁？你身上发生了什么？"

# game/code/text/text_hells_kenodox.rpy:1446
translate chinese introduce_ad1d5612:

    # Bitt "И что же ты хочешь сделать этой палочкой? Ударить меня?"
    Bitt "你拿着那根棍子想干什么？打我？"

# game/code/text/text_hells_kenodox.rpy:1448
translate chinese introduce_273966eb:

    # Bitt "Лучше бы тебе сломать мой позвоночник с первого удара. Иначе я ударю в ответ."
    Bitt "你最好第一下就打断我的脊椎。否则，我会还手。"

# game/code/text/text_hells_kenodox.rpy:1452
translate chinese introduce_a07752ca:

    # Police "Ч-что?.."
    Police "什……什么？"

# game/code/text/text_hells_kenodox.rpy:1458
translate chinese introduce_bbd40188:

    # Dm "Я им займусь, госпожа Горечь."
    Dm "我来处理他，苦涩夫人。"

# game/code/text/text_hells_kenodox.rpy:1462
translate chinese introduce_2b7c3f8b:

    # This "Пробиться к грузовым лифтам оказалось до смешного легко. После чего нас стало больше."
    This "到达货运电梯的过程轻松得可笑。之后，我们的队伍壮大了。"

# game/code/text/text_hells_kenodox.rpy:1463
translate chinese introduce_0bc3a373:

    # This "Гладкокожие люди в костюмах из ткани падали от одного удара. Казалось, они панически боялись боли."
    This "皮肤光滑、穿着西装的男人一击便倒。他们似乎对疼痛有着绝对的恐惧。"

# game/code/text/text_hells_kenodox.rpy:1464
translate chinese introduce_a990ba29:

    # This "Зачем они кричат? Почему так боятся? Боль очищает разум, ярким светом выжигает из души все лишние мысли и сомнения. Боль заглушает чужие голоса в голове."
    This "他们为什么尖叫？为什么如此害怕？疼痛能让人头脑清醒。一道强光会烧尽灵魂中所有不必要的思绪与疑虑。疼痛能淹没我脑中他人的声音。"

# game/code/text/text_hells_kenodox.rpy:1465
translate chinese introduce_f5e82fcc:

    # This "Жители Города сражались палками, камнями, оторванными конечностями других людей. Отчаянное, отвратительное безумие."
    This "城市的人们用棍棒、石头、他人撕裂的肢体战斗。一种绝望而令人作呕的疯狂。"

# game/code/text/text_hells_kenodox.rpy:1466
translate chinese introduce_0874186b:

    # This "На этом фоне спокойствие поднявшихся шахтёров радовало глаз. Равномерный посвист кирки, ломающей грудную клетку так же легко, как стену. Раз-два. Привычно. Именно так, как и должно быть."
    This "在此背景下，不断涌现的矿工们那份平静令人赏心悦目。鹤嘴锄击碎胸骨如同击穿墙壁般轻易，发出平稳的哨音。一下，两下。例行公事。本该如此。"

# game/code/text/text_hells_kenodox.rpy:1467
translate chinese introduce_5074d754:

    # This "Словно услышав крики и учуяв пролившуюся кровь, снизу вслед за нами поднялась плоть."
    This "仿佛听到了尖叫，闻到了泼洒的鲜血，血肉从下方涌上来追随我们。"

# game/code/text/text_hells_kenodox.rpy:1473
translate chinese introduce_3c45a144:

    # This "…"
    This "……"

# game/code/text/text_hells_kenodox.rpy:1482
translate chinese introduce_3871332f:

    # This "Дело сделано. Мир захвачен и исправлен, очищен от лишнего страдания."
    This "事情办完了。世界被占领、被固定，清除了不必要的苦难。"

# game/code/text/text_hells_kenodox.rpy:1483
translate chinese introduce_eee22ff3:

    # This "Оставлено только страдание необходимое. Допустимое и разрешённое. И потому приятное."
    This "只剩下必要的苦难。可接受的，被允许的。也因此，是令人愉悦的。"

# game/code/text/text_hells_kenodox.rpy:1484
translate chinese introduce_8d3c32c8:

    # Bitt "Оглянись вокруг. Это сделал ты."
    Bitt "看看四周。你做到了。"

# game/code/text/text_hells_kenodox.rpy:1485
translate chinese introduce_7d2e0895:

    # Bitt "Выглядит неплохо, на мой вкус. Скоро моя коллекция наконец завершится. Спасибо."
    Bitt "看起来不错，很合我的口味。很快，我的收藏就终于要完整了。谢谢你。"

# game/code/text/text_hells_kenodox.rpy:1486
translate chinese introduce_cd699732:

    # Bitt "Ты рад?"
    Bitt "你开心吗？"

# game/code/text/text_hells_kenodox.rpy:1487
translate chinese introduce_8c5033fd:

    # Kav "Я…"
    Kav "我……"

# game/code/text/text_hells_kenodox.rpy:1488
translate chinese introduce_3639604e:

    # This "Я рад? Радость не была моей целью. Я делал это не ради веселья или удовольствия."
    This "我开心吗？快乐并非我的目标。我做这些不是为了取乐或愉悦。"

# game/code/text/text_hells_kenodox.rpy:1489
translate chinese introduce_356a70a6:

    # This "Я сделал это ради людей."
    This "我是为了人们。"

# game/code/text/text_hells_kenodox.rpy:1490
translate chinese introduce_43fb388c:

    # This "Поймёт ли она меня? Поймёт ли меня хоть кто-нибудь?"
    This "她会理解我吗？会有人理解我吗？"

# game/code/text/text_hells_kenodox.rpy:1491
translate chinese introduce_0b90bdfa:

    # Kav "Я спокоен."
    Kav "我很平静。"

# game/code/text/text_hells_kenodox.rpy:1492
translate chinese introduce_d103993d:

    # This "Меня поймёт любой, кто пережил то же, что и я. Думаю, таких людей не слишком много."
    This "任何经历过我所经历之事的人，都会理解我。我想这样的人不会太多。"

# game/code/text/text_hells_kenodox.rpy:1493
translate chinese introduce_fb65a7d5:

    # This "Но это больше не имеет значения. Скоро закончатся те, кому нужно что-то объяснять. Скоро некому будет задавать вопросы."
    This "但这已经不重要了。很快，就不会再有人需要解释什么。很快，就不会再有人提问。"

# game/code/text/text_hells_kenodox.rpy:1494
translate chinese introduce_edeba5d7:

    # This "Одни люди кормят своими телами других. Оставшееся впитывает гигантская масса вечной, бессмертной плоти."
    This "一些人将自己的身体喂给他人。一个巨大、永恒、不朽的血肉团块吞噬着其余部分。"

# game/code/text/text_hells_kenodox.rpy:1495
translate chinese introduce_740e44ff:

    # This "Пройдёт время, пусть годы или столетия, но даже последний, самый упрямый демон сдастся. Утихнет пламя, снедающее его душу и разум. Он ляжет в мягкую и влажную колыбель, которая поглотит его тело."
    This "时间会流逝，数年或数个世纪，但即使是最顽强、最固执的恶魔也会屈服。那吞噬他们灵魂与心智的火焰终将平息。他们会躺进那柔软湿润、将吞噬他们肉体的摇篮。"

# game/code/text/text_hells_kenodox.rpy:1496
translate chinese introduce_5b92d31c:

    # This "Может быть, это буду я."
    This "也许那会是我。"

# game/code/text/text_hells_kenodox.rpy:1497
translate chinese introduce_b51d0db9:

    # This "Разумная, самоочевидная система. Сокращено и отброшено всё лишнее, пропущены промежуточные шаги."
    This "一个合理、不言自明的系统。一切多余之物都被削减、丢弃。中间步骤被跳过。"

# game/code/text/text_hells_kenodox.rpy:1498
translate chinese introduce_a90aa641:

    # This "Словно шар, который катится с горы в ямку. Словно химическая реакция, вырабатывающая свои реагенты до конца."
    This "如同滚下山坡落入洞中的球。如同化学反应将反应物消耗殆尽。"

# game/code/text/text_hells_kenodox.rpy:1499
translate chinese introduce_1d1b3be1:

    # This "Словно гаснущий огонёк свечи."
    This "如同熄灭的烛火。"

# game/code/text/text_hells_kenodox.rpy:1505
translate chinese introduce_31c3f229:

    # This "Концовка: «Демон»."
    This "结局：«恶魔»。"

